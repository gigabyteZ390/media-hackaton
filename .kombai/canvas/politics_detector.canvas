      "html": "<style data-kid=\"0\">\n  @import url('https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css');\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --background: #F7F8FA;\n    --surface: #FFFFFF;\n    --navy: #172033;\n    --consistency: #2563EB;\n    --factuality: #16A34A;\n    --warning: #D97706;\n    --danger: #DC2626;\n  }\n\n  .font-sans-main { font-family: 'Pretendard', 'Inter', sans-serif; }\n  .font-mono-data { font-family: 'JetBrains Mono', monospace; }\n\n  @keyframes marquee-belt {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  .animate-conveyor {\n    animation: marquee-belt 15s linear infinite;\n    width: 200%;\n  }\n\n  .glass-header {\n    background: rgba(255, 255, 255, 0.7);\n    backdrop-filter: blur(16px);\n    -webkit-backdrop-filter: blur(16px);\n  }\n  \n  .axis-glow-effect {\n    box-shadow: 0 0 20px rgba(37, 99, 235, 0.4);\n  }\n\n  .timeline-line-gradient {\n    background: linear-gradient(to bottom, #2563EB, #16A34A, #D97706, #DC2626);\n  }\n\n  /* Lenis CSS is needed in body because head is managed */\n  .lenis.lenis-smooth { height: auto; }\n  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }\n  .lenis.lenis-stopped { overflow: hidden; }\n  .lenis.lenis-scrolling iframe { pointer-events: none; }\n</style>\n\n<div class=\"font-sans-main bg-[#F7F8FA] text-[#172033] min-h-screen selection:bg-blue-100 selection:text-blue-900 overflow-x-clip\" data-kid=\"1\">\n  \n  <nav id=\"top-nav\" class=\"fixed top-0 w-full z-[100] px-6 py-5\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-3 group cursor-pointer\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[#172033] rounded-lg flex items-center justify-center shadow-lg ring-1 ring-white/10 group-hover:scale-105 transition-transform\" data-kid=\"5\">\n          <i class=\"ti ti-binary text-white text-2xl\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"font-bold text-xl tracking-tight text-white\" id=\"logo-text\" data-kid=\"7\">VeriDesk</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-10\" data-kid=\"8\">\n        <a href=\"#\" class=\"text-xs font-black uppercase tracking-[0.2em] text-white/70 hover:text-white transition-colors\" data-kid=\"9\">Methodology</a>\n        <a href=\"#\" class=\"text-xs font-black uppercase tracking-[0.2em] text-white/70 hover:text-white transition-colors\" data-kid=\"10\">Source DB</a>\n        <a href=\"#\" class=\"px-6 py-2.5 bg-white/10 hover:bg-white/20 border border-white/20 rounded-xl text-xs font-black uppercase tracking-[0.2em] text-white transition-all backdrop-blur-md\" data-kid=\"11\">Trial Access</a>\n      </div>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative bg-[#172033] pt-48 pb-52 overflow-hidden\" data-kid=\"12\">\n    \n    <div class=\"absolute inset-0 opacity-10 pointer-events-none\" data-kid=\"13\">\n       <video src=\"https://videos.pexels.com/video-files/30308684/12992533_640_360_24fps.mp4\" poster=\"https://images.pexels.com/videos/30308684/3d-3d-animation-3danimation-blender3d-30308684.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover\" data-kid=\"14\"></video>\n    </div>\n\n    <div class=\"max-w-7xl mx-auto px-6 relative z-10 flex flex-col lg:flex-row items-center gap-24\" data-kid=\"15\">\n      <div class=\"w-full lg:w-7/12 text-center lg:text-left space-y-8\" data-kid=\"16\">\n        <div class=\"inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-slate-300 text-[10px] font-bold uppercase tracking-[0.2em]\" data-kid=\"17\">\n          Evidence-First Verification\n        </div>\n        <h1 class=\"text-6xl lg:text-7xl font-bold text-white leading-[1.05] tracking-tight\" data-kid=\"18\">\n          Verify Political <br data-kid=\"19\">\n          <span class=\"text-blue-500\" data-kid=\"20\">Consistency.</span>\n        </h1>\n        <p class=\"text-lg text-slate-400 max-w-xl mx-auto lg:mx-0 leading-relaxed font-medium\" data-kid=\"21\">\n          정치인의 발언을 과거 인터뷰 및 공공 데이터와 대조하여 사실관계와 입장 변화를 실시간으로 추적하는 AI 검증 시스템입니다.\n        </p>\n        \n        \n        <div class=\"flex flex-col sm:flex-row items-center gap-3 p-2 bg-white/5 border border-white/10 rounded-2xl max-w-2xl mx-auto lg:mx-0 backdrop-blur-3xl shadow-2xl\" data-kid=\"22\">\n          <div class=\"flex items-center gap-4 flex-1 w-full px-5\" data-kid=\"23\">\n            <i class=\"ti ti-link text-slate-500 text-2xl\" data-kid=\"24\"></i>\n            <input type=\"text\" placeholder=\"Paste YouTube link or speech transcript...\" class=\"bg-transparent border-none outline-hidden py-4 flex-1 text-white placeholder:text-slate-600 font-medium text-sm\" data-kid=\"25\">\n          </div>\n          <button class=\"w-full sm:w-auto bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-xl font-bold uppercase tracking-widest text-[11px] transition-all flex items-center justify-center gap-3 group\" data-kid=\"26\">\n            Analyze Speech <i class=\"ti ti-arrow-right group-hover:translate-x-1 transition-transform\" data-kid=\"27\"></i>\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"w-full lg:w-2/5 flex justify-center\" data-kid=\"28\">\n        <div class=\"relative w-96 h-96 flex items-center justify-center group\" id=\"hero-axes\" data-kid=\"29\">\n          <div class=\"absolute inset-0 rounded-full border border-white/5 scale-110\" data-kid=\"30\"></div>\n          <div class=\"absolute inset-0 rounded-full border border-white/5 scale-125\" data-kid=\"31\"></div>\n          \n          \n          <div class=\"absolute w-full h-px bg-linear-to-r from-transparent via-white/20 to-transparent\" data-kid=\"32\"></div>\n          <div class=\"absolute h-full w-px bg-linear-to-b from-transparent via-white/20 to-transparent\" data-kid=\"33\"></div>\n          \n          \n          <div class=\"absolute top-0 left-1/2 -translate-x-1/2 -translate-y-12 text-[11px] font-black uppercase tracking-[0.5em] text-green-400/80\" data-kid=\"34\">Factuality</div>\n          <div class=\"absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-12 text-[11px] font-black uppercase tracking-[0.5em] text-slate-600\" data-kid=\"35\">Subjectivity</div>\n          <div class=\"absolute left-0 top-1/2 -translate-x-20 -translate-y-1/2 text-[11px] font-black uppercase tracking-[0.5em] text-blue-400/80 -rotate-90\" data-kid=\"36\">Consistency</div>\n          <div class=\"absolute right-0 top-1/2 translate-x-20 -translate-y-1/2 text-[11px] font-black uppercase tracking-[0.5em] text-red-500/80 rotate-90\" data-kid=\"37\">Contradiction</div>\n          \n          \n          <div class=\"w-40 h-40 rounded-full border border-white/10 bg-white/5 flex items-center justify-center backdrop-blur-xl relative z-10\" data-kid=\"38\">\n             <div class=\"w-24 h-24 rounded-full border border-white/20 flex items-center justify-center bg-white/5\" data-kid=\"39\">\n                <i class=\"ti ti-scan text-6xl text-blue-400/80\" data-kid=\"40\"></i>\n             </div>\n          </div>\n          \n          \n          <div class=\"absolute top-[20%] right-[30%] w-4 h-4 bg-red-500/20 rounded-full blur-[4px]\" data-kid=\"41\"></div>\n          <div class=\"absolute bottom-[25%] left-[20%] w-3 h-3 bg-green-500/20 rounded-full blur-[4px]\" data-kid=\"42\"></div>\n          <div class=\"absolute top-[60%] right-[15%] w-2 h-2 bg-blue-500/20 rounded-full blur-[4px]\" data-kid=\"43\"></div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-white border-b border-slate-100 overflow-hidden py-5\" data-kid=\"44\">\n    <div class=\"max-w-7xl mx-auto px-6 flex items-center gap-10\" data-kid=\"45\">\n      <div class=\"flex-shrink-0 text-[11px] font-black text-blue-600 uppercase tracking-[0.4em] flex items-center gap-4\" data-kid=\"46\">\n        <span class=\"w-2.5 h-2.5 rounded-full bg-blue-600 shadow-[0_0_10px_rgba(37,99,235,0.4)]\" data-kid=\"47\"></span>\n        Processing Live Data\n      </div>\n      <div class=\"flex-1 relative h-8 overflow-hidden\" data-kid=\"48\">\n        <div class=\"absolute inset-0 flex items-center gap-20 animate-conveyor whitespace-nowrap\" data-kid=\"49\">\n          <div class=\"flex items-center gap-3 text-slate-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"50\"><i class=\"ti ti-database-search\" data-kid=\"51\"></i> Archive Matching</div>\n          <div class=\"flex items-center gap-3 text-slate-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"52\"><i class=\"ti ti-world-search\" data-kid=\"53\"></i> Cross-Web Check</div>\n          <div class=\"flex items-center gap-3 text-slate-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"54\"><i class=\"ti ti-waveform\" data-kid=\"55\"></i> Voice-to-Text</div>\n          <div class=\"flex items-center gap-3 text-slate-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"56\"><i class=\"ti ti-binary\" data-kid=\"57\"></i> Sentiment Axis</div>\n          <div class=\"flex items-center gap-3 text-slate-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"58\"><i class=\"ti ti-sparkles\" data-kid=\"59\"></i> AI Reasoning</div>\n          \n          <div class=\"flex items-center gap-3 text-slate-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"60\"><i class=\"ti ti-database-search\" data-kid=\"61\"></i> Archive Matching</div>\n          <div class=\"flex items-center gap-3 text-slate-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"62\"><i class=\"ti ti-world-search\" data-kid=\"63\"></i> Cross-Web Check</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <div id=\"results-dashboard\" class=\"sticky top-[80px] z-50 glass-header border-b border-slate-200 px-6 py-5 shadow-sm -translate-y-[200%]\" data-kid=\"64\">\n    <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6\" data-kid=\"65\">\n      <div class=\"flex items-center gap-5\" data-kid=\"66\">\n        <div class=\"w-12 h-12 rounded-2xl bg-[#172033] flex items-center justify-center text-white shadow-2xl\" data-kid=\"67\">\n          <i class=\"ti ti-layout-dashboard text-2xl\" data-kid=\"68\"></i>\n        </div>\n        <div data-kid=\"69\">\n          <h2 class=\"text-sm font-black uppercase tracking-wider text-[#172033]\" data-kid=\"70\">Analysis Results</h2>\n          <p class=\"text-[10px] text-slate-500 font-mono-data uppercase tracking-[0.2em]\" data-kid=\"71\">Session: VERI-0708-Z</p>\n        </div>\n      </div>\n      \n      <div class=\"flex flex-wrap items-center justify-center gap-10\" data-kid=\"72\">\n        <div class=\"flex items-center gap-12 md:border-r border-slate-200 md:pr-12\" data-kid=\"73\">\n          <div class=\"flex flex-col items-center\" data-kid=\"74\">\n            <span class=\"text-[10px] font-black text-blue-600 uppercase tracking-[0.3em] mb-2\" data-kid=\"75\">Consistency</span>\n            <div class=\"flex items-center gap-3\" data-kid=\"76\">\n              <span class=\"text-3xl font-black text-slate-800 font-mono-data\" data-kid=\"77\">72%</span>\n              <div class=\"w-16 h-2 bg-slate-100 rounded-full overflow-hidden\" data-kid=\"78\">\n                <div class=\"h-full bg-blue-500 w-[72%]\" data-kid=\"79\"></div>\n              </div>\n            </div>\n          </div>\n          <div class=\"flex flex-col items-center\" data-kid=\"80\">\n            <span class=\"text-[10px] font-black text-green-600 uppercase tracking-[0.3em] mb-2\" data-kid=\"81\">Accuracy</span>\n            <div class=\"flex items-center gap-3\" data-kid=\"82\">\n              <span class=\"text-3xl font-black text-slate-800 font-mono-data\" data-kid=\"83\">64%</span>\n              <div class=\"w-16 h-2 bg-slate-100 rounded-full overflow-hidden\" data-kid=\"84\">\n                <div class=\"h-full bg-green-500 w-[64%]\" data-kid=\"85\"></div>\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        <div class=\"flex gap-3\" data-kid=\"86\">\n          <div class=\"px-4 py-2 rounded-xl bg-red-50 text-red-600 text-[10px] font-black border border-red-100 shadow-xs uppercase tracking-widest\" data-kid=\"87\">5 Contradictions</div>\n          <div class=\"px-4 py-2 rounded-xl bg-slate-50 text-slate-500 text-[10px] font-black border border-slate-100 shadow-xs uppercase tracking-widest\" data-kid=\"88\">4 Unverifiable</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <main class=\"relative py-32 pb-60\" data-kid=\"89\">\n    \n    <div class=\"absolute left-1/2 top-0 bottom-0 w-px bg-slate-200 -translate-x-1/2 z-0 hidden lg:block overflow-hidden\" data-kid=\"90\">\n       <div class=\"absolute top-0 left-0 w-full h-full timeline-line-gradient opacity-20\" data-kid=\"91\"></div>\n    </div>\n\n    <div class=\"max-w-7xl mx-auto px-6 space-y-40 relative z-10\" data-kid=\"92\">\n      \n      \n      <article class=\"timeline-node group flex flex-col lg:flex-row items-center flex-wrap\" data-id=\"c1\" data-kid=\"93\">\n        \n        <div class=\"order-2 lg:order-1 flex-1 lg:pr-12 text-center lg:text-right\" data-kid=\"94\">\n          <div class=\"text-[9px] font-black text-slate-400 mb-4 uppercase tracking-[0.4em] font-mono-data\" data-kid=\"95\">00:01:24 — SEGMENT 03</div>\n          <h3 class=\"text-xl lg:text-2xl font-bold text-[#172033] leading-snug\" data-kid=\"96\">\n            \"청년 실업률은 지난 정부보다 <span class=\"text-red-600\" data-kid=\"97\">두 배 이상 낮아졌습니다.</span>\"\n          </h3>\n          <p class=\"mt-4 text-slate-500 text-sm max-w-sm lg:ml-auto leading-relaxed\" data-kid=\"98\">\n            정부 공식 통계 및 본인의 3월 인터뷰와 충돌하는 진술입니다.\n          </p>\n        </div>\n\n        \n        <div class=\"order-1 lg:order-2 flex items-center justify-center w-24 h-24 relative\" data-kid=\"99\">\n           <div class=\"w-4 h-4 rounded-full bg-white border-4 border-red-500 axis-dot-border z-20 hover:scale-150 transition-transform cursor-pointer\" data-kid=\"100\"></div>\n        </div>\n\n        \n        <div class=\"order-3 lg:order-3 flex-1 lg:pl-12\" data-kid=\"101\">\n          <div class=\"flex flex-wrap gap-3 mb-6 justify-center lg:justify-start\" data-kid=\"102\">\n            <span class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-red-100 text-red-700 text-[11px] font-black border border-red-200 uppercase tracking-widest\" data-kid=\"103\">\n              <i class=\"ti ti-arrows-diff\" data-kid=\"104\"></i> Inconsistent\n            </span>\n            <span class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-red-100/50 text-red-700 text-[11px] font-black border border-red-200/50 uppercase tracking-widest\" data-kid=\"105\">\n              <i class=\"ti ti-circle-x\" data-kid=\"106\"></i> False Claim\n            </span>\n          </div>\n          <div class=\"max-w-xs mx-auto lg:mx-0 bg-white p-5 rounded-2xl border border-slate-100 shadow-sm\" data-kid=\"107\">\n            <div class=\"flex items-center justify-between mb-3\" data-kid=\"108\">\n               <span class=\"text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]\" data-kid=\"109\">AI Confidence</span>\n               <span class=\"text-xs font-mono-data font-black text-red-600\" data-kid=\"110\">82.4%</span>\n            </div>\n            <div class=\"h-2.5 bg-slate-100 rounded-full overflow-hidden\" data-kid=\"111\">\n               <div class=\"h-full bg-red-500 w-[82%]\" data-kid=\"112\"></div>\n            </div>\n            <button class=\"expand-evidence-trigger mt-6 w-full py-3 bg-blue-50 hover:bg-blue-100 text-blue-600 text-[10px] font-black uppercase tracking-[0.2em] rounded-xl transition-all flex items-center justify-center gap-2 group/btn\" data-target=\"drawer-c1\" data-kid=\"113\">\n              Analyze Evidence <i class=\"ti ti-chevron-down group-hover/btn:translate-y-1 transition-transform\" data-kid=\"114\"></i>\n            </button>\n          </div>\n        </div>\n\n        \n        <div id=\"drawer-c1\" class=\"evidence-drawer-content hidden w-full mt-16 bg-white rounded-[2.5rem] shadow-[0_50px_100px_rgba(0,0,0,0.08)] border border-slate-200 overflow-hidden order-4\" data-kid=\"115\">\n           <div class=\"flex flex-col md:flex-row\" data-kid=\"116\">\n              <div class=\"w-full md:w-72 bg-slate-50/50 border-r border-slate-200 p-8 space-y-3\" data-kid=\"117\">\n                 <button class=\"tab-trigger w-full text-left px-5 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all bg-white shadow-xl text-blue-600 border border-blue-100\" data-tab=\"consistency\" data-kid=\"118\">Self-Consistency</button>\n                 <button class=\"tab-trigger w-full text-left px-5 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all text-slate-400 hover:bg-slate-100\" data-tab=\"factuality\" data-kid=\"119\">Factuality Data</button>\n              </div>\n              <div class=\"flex-1 p-10\" data-kid=\"120\">\n                 <div class=\"tab-pane-consistency space-y-10\" data-kid=\"121\">\n                    <div data-kid=\"122\">\n                       <h4 class=\"text-[11px] font-black text-slate-400 uppercase tracking-[0.3em] mb-6\" data-kid=\"123\">Chronological Contradiction Map</h4>\n                       <div class=\"grid grid-cols-1 md:grid-cols-[1fr,auto,1fr] gap-8 items-center\" data-kid=\"124\">\n                          <div class=\"p-6 bg-red-50/50 rounded-3xl border border-red-100\" data-kid=\"125\">\n                             <div class=\"flex justify-between mb-4\" data-kid=\"126\">\n                                <span class=\"text-[9px] font-black text-red-400 uppercase tracking-widest\" data-kid=\"127\">Present Speech</span>\n                                <span class=\"text-[9px] font-mono-data text-red-400\" data-kid=\"128\">JULY 2024</span>\n                             </div>\n                             <p class=\"text-base font-black text-red-900 leading-relaxed italic\" data-kid=\"129\">\"청년 실업률은 지난 정부보다 두 배 이상 낮아졌습니다.\"</p>\n                          </div>\n                          <div class=\"flex items-center justify-center text-slate-300\" data-kid=\"130\">\n                             <i class=\"ti ti-arrows-left-right text-3xl\" data-kid=\"131\"></i>\n                          </div>\n                          <div class=\"p-6 bg-slate-50 rounded-3xl border border-slate-200\" data-kid=\"132\">\n                             <div class=\"flex justify-between mb-4\" data-kid=\"133\">\n                                <span class=\"text-[9px] font-black text-slate-400 uppercase tracking-widest\" data-kid=\"134\">Past Interview (MBC)</span>\n                                <span class=\"text-[9px] font-mono-data text-slate-400\" data-kid=\"135\">MARCH 2024</span>\n                             </div>\n                             <p class=\"text-base font-bold text-slate-700 leading-relaxed\" data-kid=\"136\">\"청년 실업 문제는 여전히 심각한 정체기이며 단기적 해결은 불가능합니다.\"</p>\n                          </div>\n                       </div>\n                    </div>\n                    <div class=\"bg-blue-600 p-8 rounded-[2rem] text-white flex gap-6 shadow-2xl shadow-blue-500/20\" data-kid=\"137\">\n                       <i class=\"ti ti-robot text-4xl opacity-50\" data-kid=\"138\"></i>\n                       <div class=\"space-y-2\" data-kid=\"139\">\n                          <p class=\"text-[10px] font-black uppercase tracking-[0.4em] text-white/60\" data-kid=\"140\">AI Reasoning Output</p>\n                          <p class=\"text-sm font-medium leading-relaxed\" data-kid=\"141\">\n                            6개월 전 발언과 현재의 주장이 통계적 근거 없이 180도 전환되었습니다. 이는 유권자에게 왜곡된 정보를 전달하려는 의도가 다분하며, 자기 일관성 점수가 유의미하게 하락하는 주요 원인입니다.\n                          </p>\n                       </div>\n                    </div>\n                 </div>\n              </div>\n           </div>\n           <div class=\"bg-slate-900 py-4 px-10 text-[9px] font-black text-center text-white/40 uppercase tracking-[0.5em]\" data-kid=\"142\">\n              Human Journalist Review Required for Official Press Verification\n           </div>\n        </div>\n      </article>\n\n      \n      <article class=\"timeline-node group flex flex-col lg:flex-row items-center flex-wrap\" data-id=\"c2\" data-kid=\"143\">\n        <div class=\"order-2 lg:order-1 flex-1 lg:pr-12 text-center lg:text-right\" data-kid=\"144\">\n          <div class=\"text-[9px] font-black text-slate-400 mb-4 uppercase tracking-[0.4em] font-mono-data\" data-kid=\"145\">00:02:45 — SEGMENT 07</div>\n          <h3 class=\"text-xl lg:text-2xl font-bold text-[#172033] leading-snug\" data-kid=\"146\">\n            \"복지 사각지대 해소를 위해 예산을 <span class=\"text-green-600\" data-kid=\"147\">15% 증액하겠습니다.</span>\"\n          </h3>\n          <p class=\"mt-4 text-slate-500 text-sm max-w-sm lg:ml-auto leading-relaxed\" data-kid=\"148\">\n            2025년 정부 예산안 초안 및 소속 정당 공약과 일치합니다.\n          </p>\n        </div>\n\n        <div class=\"order-1 lg:order-2 flex items-center justify-center w-24 h-24 relative\" data-kid=\"149\">\n           <div class=\"w-4 h-4 rounded-full bg-white border-4 border-green-500 axis-dot-border z-20 hover:scale-150 transition-transform cursor-pointer\" data-kid=\"150\"></div>\n        </div>\n\n        <div class=\"order-3 lg:order-3 flex-1 lg:pl-12\" data-kid=\"151\">\n          <div class=\"flex flex-wrap gap-3 mb-6 justify-center lg:justify-start\" data-kid=\"152\">\n            <span class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-green-100 text-green-700 text-[11px] font-black border border-green-200 uppercase tracking-widest\" data-kid=\"153\">\n              <i class=\"ti ti-checks\" data-kid=\"154\"></i> Consistent\n            </span>\n            <span class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-green-100/50 text-green-700 text-[11px] font-black border border-green-200/50 uppercase tracking-widest\" data-kid=\"155\">\n              <i class=\"ti ti-circle-check\" data-kid=\"156\"></i> Fact Verified\n            </span>\n          </div>\n          <div class=\"max-w-xs mx-auto lg:mx-0 bg-white p-5 rounded-2xl border border-slate-100 shadow-sm\" data-kid=\"157\">\n            <div class=\"flex items-center justify-between mb-3\" data-kid=\"158\">\n               <span class=\"text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]\" data-kid=\"159\">AI Confidence</span>\n               <span class=\"text-xs font-mono-data font-black text-green-600\" data-kid=\"160\">94.1%</span>\n            </div>\n            <div class=\"h-2.5 bg-slate-100 rounded-full overflow-hidden\" data-kid=\"161\">\n               <div class=\"h-full bg-green-500 w-[94%]\" data-kid=\"162\"></div>\n            </div>\n          </div>\n        </div>\n      </article>\n\n      \n      <article class=\"timeline-node group flex flex-col lg:flex-row items-center flex-wrap\" data-id=\"c3\" data-kid=\"163\">\n        <div class=\"order-2 lg:order-1 flex-1 lg:pr-12 text-center lg:text-right\" data-kid=\"164\">\n          <div class=\"text-[9px] font-black text-slate-400 mb-4 uppercase tracking-[0.4em] font-mono-data\" data-kid=\"165\">00:04:12 — SEGMENT 12</div>\n          <h3 class=\"text-xl lg:text-2xl font-bold text-[#172033] leading-snug\" data-kid=\"166\">\n            \"이 정책은 <span class=\"text-amber-600\" data-kid=\"167\">세계에서 가장 진보적인</span> 정책입니다.\"\n          </h3>\n          <p class=\"mt-4 text-slate-500 text-sm max-w-sm lg:ml-auto leading-relaxed\" data-kid=\"168\">\n            주관적 가치 판단이 포함된 표현으로 팩트체크가 불가능합니다.\n          </p>\n        </div>\n\n        <div class=\"order-1 lg:order-2 flex items-center justify-center w-24 h-24 relative\" data-kid=\"169\">\n           <div class=\"w-4 h-4 rounded-full bg-white border-4 border-amber-500 axis-dot-border z-20 hover:scale-150 transition-transform cursor-pointer\" data-kid=\"170\"></div>\n        </div>\n\n        <div class=\"order-3 lg:order-3 flex-1 lg:pl-12\" data-kid=\"171\">\n          <div class=\"flex flex-wrap gap-3 mb-6 justify-center lg:justify-start\" data-kid=\"172\">\n            <span class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-slate-100 text-slate-500 text-[11px] font-black border border-slate-200 uppercase tracking-widest\" data-kid=\"173\">\n              <i class=\"ti ti-minus\" data-kid=\"174\"></i> Subjective\n            </span>\n            <span class=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-amber-100 text-amber-700 text-[11px] font-black border border-amber-200 uppercase tracking-widest\" data-kid=\"175\">\n              <i class=\"ti ti-alert-triangle\" data-kid=\"176\"></i> Unverifiable\n            </span>\n          </div>\n          <div class=\"max-w-xs mx-auto lg:mx-0 opacity-40\" data-kid=\"177\">\n            <div class=\"flex items-center justify-between mb-3\" data-kid=\"178\">\n               <span class=\"text-[10px] font-black text-slate-400 uppercase tracking-[0.3em]\" data-kid=\"179\">AI Confidence</span>\n               <span class=\"text-xs font-mono-data font-black text-slate-500\" data-kid=\"180\">N/A</span>\n            </div>\n            <div class=\"h-2.5 bg-slate-100 rounded-full overflow-hidden\" data-kid=\"181\">\n               <div class=\"h-full bg-slate-300 w-0\" data-kid=\"182\"></div>\n            </div>\n          </div>\n        </div>\n      </article>\n\n    </div>\n  </main>\n\n  \n  <footer class=\"bg-[#172033] text-white pt-32 pb-16\" data-kid=\"183\">\n    <div class=\"max-w-7xl mx-auto px-6\" data-kid=\"184\">\n      <div class=\"grid grid-cols-1 md:grid-cols-4 gap-20 pb-20 border-b border-white/5\" data-kid=\"185\">\n        <div class=\"col-span-1 md:col-span-2 space-y-10\" data-kid=\"186\">\n          <div class=\"flex items-center gap-4\" data-kid=\"187\">\n            <div class=\"w-12 h-12 bg-white rounded-2xl flex items-center justify-center shadow-2xl\" data-kid=\"188\">\n              <i class=\"ti ti-activity-heartbeat text-[#172033] text-3xl\" data-kid=\"189\"></i>\n            </div>\n            <span class=\"font-black text-3xl tracking-tighter\" data-kid=\"190\">VeriDesk AI</span>\n          </div>\n          <p class=\"text-slate-400 max-w-md leading-relaxed text-base\" data-kid=\"191\">\n            정치적 이해관계를 배제하고 오직 데이터와 일관성만을 추적합니다. <br data-kid=\"192\">\n            우리는 더 나은 민주주의를 위한 투명한 기술을 만듭니다.\n          </p>\n          <div class=\"flex gap-4\" data-kid=\"193\">\n             <a href=\"#\" class=\"w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-white/10 transition-colors\" data-kid=\"194\"><i class=\"ti ti-brand-x\" data-kid=\"195\"></i></a>\n             <a href=\"#\" class=\"w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-white/10 transition-colors\" data-kid=\"196\"><i class=\"ti ti-brand-github\" data-kid=\"197\"></i></a>\n             <a href=\"#\" class=\"w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center hover:bg-white/10 transition-colors\" data-kid=\"198\"><i class=\"ti ti-brand-linkedin\" data-kid=\"199\"></i></a>\n          </div>\n        </div>\n        <div data-kid=\"200\">\n          <h4 class=\"text-[10px] font-black uppercase tracking-[0.5em] mb-8 text-blue-500\" data-kid=\"201\">Navigation</h4>\n          <ul class=\"space-y-5 text-sm font-bold text-slate-400\" data-kid=\"202\">\n            <li data-kid=\"203\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"204\">Analyzer Engine</a></li>\n            <li data-kid=\"205\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"206\">API for Journalists</a></li>\n            <li data-kid=\"207\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"208\">Dataset Documentation</a></li>\n            <li data-kid=\"209\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"210\">Public Audit Log</a></li>\n          </ul>\n        </div>\n        <div data-kid=\"211\">\n          <h4 class=\"text-[10px] font-black uppercase tracking-[0.5em] mb-8 text-green-500\" data-kid=\"212\">Governance</h4>\n          <ul class=\"space-y-5 text-sm font-bold text-slate-400\" data-kid=\"213\">\n            <li data-kid=\"214\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"215\">AI Ethics Board</a></li>\n            <li data-kid=\"216\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"217\">Conflict of Interest</a></li>\n            <li data-kid=\"218\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"219\">Privacy Shield</a></li>\n            <li data-kid=\"220\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"221\">Legal Terms</a></li>\n          </ul>\n        </div>\n      </div>\n      <div class=\"mt-12 flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] font-black text-slate-600 uppercase tracking-[0.3em]\" data-kid=\"222\">\n        <p data-kid=\"223\">&copy; 2024 VeriDesk Intelligence Systems. All Rights Reserved.</p>\n        <div class=\"flex gap-10\" data-kid=\"224\">\n          <span data-kid=\"225\">v2.4.1-STABLE</span>\n          <span data-kid=\"226\">Seoul, South Korea</span>\n        </div>\n      </div>\n    </div>\n  </footer>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"227\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"228\"></script>\n<script type=\"module\" data-kid=\"229\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  \n  // Initialize Lenis for Smooth Scroll\n  const lenis = new Lenis();\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // GSAP Configuration\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Hero Axes Rotation Animation\n  gsap.to(\"#hero-axes\", {\n    rotate: 360,\n    duration: 240,\n    repeat: -1,\n    ease: \"none\"\n  });\n\n  // Sticky Dashboard Activation\n  ScrollTrigger.create({\n    trigger: \"header\",\n    start: \"bottom top\",\n    onEnter: () => gsap.to(\"#results-dashboard\", { y: 0, duration: 0.6, ease: \"power4.out\" }),\n    onLeaveBack: () => gsap.to(\"#results-dashboard\", { y: \"-100%\", duration: 0.4, ease: \"power4.in\" })\n  });\n\n  // Nav Bar Background Transition\n  ScrollTrigger.create({\n    trigger: \"header\",\n    start: \"bottom 100px\",\n    onEnter: () => {\n      gsap.to(\"#top-nav\", { backgroundColor: \"rgba(255,255,255,0.85)\", backdropFilter: \"blur(20px)\", borderBottom: \"1px solid rgba(0,0,0,0.05)\", py: \"14px\", duration: 0.5 });\n      gsap.to(\"#logo-text\", { color: \"#172033\", duration: 0.5 });\n      document.querySelectorAll(\"#top-nav a\").forEach(a => a.style.color = \"#4B5563\");\n    },\n    onLeaveBack: () => {\n      gsap.to(\"#top-nav\", { backgroundColor: \"transparent\", backdropFilter: \"blur(0px)\", borderBottom: \"0px solid transparent\", py: \"20px\", duration: 0.5 });\n      gsap.to(\"#logo-text\", { color: \"#ffffff\", duration: 0.5 });\n      document.querySelectorAll(\"#top-nav a\").forEach(a => a.style.color = \"rgba(255,255,255,0.7)\");\n    }\n  });\n\n  // Timeline Nodes Reveal\n  document.querySelectorAll('.timeline-node').forEach((node, i) => {\n    const quote = node.querySelector('.order-2');\n    const verdict = node.querySelector('.order-3');\n    const circle = node.querySelector('.order-1');\n\n    gsap.from(quote, {\n      scrollTrigger: { trigger: node, start: \"top 85%\" },\n      x: -60,\n      opacity: 0,\n      duration: 1.2,\n      ease: \"power4.out\"\n    });\n\n    gsap.from(verdict, {\n      scrollTrigger: { trigger: node, start: \"top 85%\" },\n      x: 60,\n      opacity: 0,\n      duration: 1.2,\n      ease: \"power4.out\",\n      delay: 0.1\n    });\n\n    gsap.from(circle, {\n      scrollTrigger: { trigger: node, start: \"top 85%\" },\n      scale: 0,\n      opacity: 0,\n      duration: 0.8,\n      ease: \"back.out(2)\",\n      delay: 0.3\n    });\n  });\n\n  // Drawer Expansion Logic\n  document.querySelectorAll('.expand-evidence-trigger').forEach(btn => {\n    btn.addEventListener('click', () => {\n      const targetId = btn.getAttribute('data-target');\n      const drawer = document.getElementById(targetId);\n      const icon = btn.querySelector('i');\n\n      if (drawer.classList.contains('hidden')) {\n        drawer.classList.remove('hidden');\n        gsap.fromTo(drawer, { height: 0, opacity: 0 }, { height: \"auto\", opacity: 1, duration: 0.6, ease: \"power3.out\" });\n        icon.style.transform = \"rotate(180deg)\";\n      } else {\n        gsap.to(drawer, { height: 0, opacity: 0, duration: 0.4, ease: \"power3.in\", onComplete: () => drawer.classList.add('hidden') });\n        icon.style.transform = \"rotate(0deg)\";\n      }\n    });\n  });\n</script>\n",
      "comments": [],
      "created": "2026-07-08T12:08:49.131195+00:00",
      "modified": "2026-07-08T12:08:49.131195+00:00",
      "id": "var_f48d263775c9",
      "overrides": {
        "htmlAttrs": " lang=\"ko\"",
        "bodyAttrs": " class=\"selection:bg-blue-100 selection:text-blue-900\"",
        "head": "<meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Political Statement Contradiction Detector</title>"
      },
      "viewportScrollY": 0
    },
    "var_73a9e48c45e4": {
      "type": "variant",
      "label": "Editorial Desk (Broadsheet)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 2760,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "html": "\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"0\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n<link rel=\"stylesheet\" as=\"style\" crossorigin href=\"https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css\" data-kid=\"2\">\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"3\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"4\"></script>\n<script type=\"module\" data-kid=\"5\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  const lenis = new Lenis()\n  function raf(time) {\n    lenis.raf(time)\n    requestAnimationFrame(raf)\n  }\n  requestAnimationFrame(raf)\n</script>\n\n<style data-kid=\"6\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=JetBrains+Mono:wght@400;500&display=swap');\n\n  :root {\n    --bg-merino: #FBFBF9;\n    --ink-black: #111827;\n    --editorial-slate: #475569;\n    --royal-blue: #1D4ED8;\n    --emerald-green: #059669;\n    --mustard-yellow: #D97706;\n    --brick-red: #B91C1C;\n    --paper-line: rgba(17, 24, 39, 0.15);\n  }\n\n  body {\n    background-color: var(--bg-merino);\n    color: var(--ink-black);\n    font-family: \"Pretendard\", -apple-system, BlinkMacSystemFont, system-ui, Roboto, sans-serif;\n    overflow-x: clip;\n    margin: 0;\n  }\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n  .font-sans { font-family: \"Pretendard\", sans-serif; }\n\n  .paper-texture {\n    background-image: url('https://images.unsplash.com/photo-1637325258040-d2f09636ecf6?auto=format&w=1920&q=80&fit=crop');\n    background-blend-mode: multiply;\n    background-attachment: fixed;\n    background-size: cover;\n  }\n\n  /* Broadsheet Layout Elements */\n  .masthead-rule-thick { border-top: 6px solid var(--ink-black); }\n  .masthead-rule-thin { border-top: 1px solid var(--ink-black); }\n  .column-divider { border-left: 1px solid var(--paper-line); }\n\n  .ink-fill-track {\n    height: 4px;\n    background: #e2e8f0;\n    position: relative;\n    border-radius: 0;\n  }\n  \n  .ink-fill-progress {\n    position: absolute;\n    left: 0;\n    top: 0;\n    height: 100%;\n    background: var(--ink-black);\n    width: 0%;\n  }\n\n  .card-editorial {\n    background: #ffffff;\n    position: relative;\n    border: 1px solid var(--paper-line);\n    /* No transitions - GSAP handled */\n  }\n\n  .card-editorial:hover {\n    box-shadow: 0 15px 35px rgba(0,0,0,0.04);\n  }\n\n  .verdict-line {\n    position: absolute;\n    left: 0;\n    top: 0;\n    bottom: 0;\n    width: 6px;\n  }\n\n  .evidence-drawer {\n    position: fixed;\n    right: -100%;\n    top: 0;\n    bottom: 0;\n    width: 100%;\n    max-width: 540px;\n    background: var(--bg-merino);\n    box-shadow: -20px 0 60px rgba(0,0,0,0.1);\n    z-index: 100;\n    display: flex;\n    flex-direction: column;\n    border-left: 2px solid var(--ink-black);\n  }\n\n  .glass-nav {\n    background: rgba(251, 251, 249, 0.98);\n    border-bottom: 2px solid var(--ink-black);\n  }\n\n  .btn-editorial {\n    @apply px-10 py-5 font-black uppercase tracking-[0.2em] text-[11px] rounded-none border-2 border-[var(--ink-black)] cursor-pointer;\n  }\n\n  .btn-editorial-primary {\n    @apply bg-[var(--ink-black)] text-white hover:bg-white hover:text-[var(--ink-black)] transition-colors duration-300;\n  }\n\n  .btn-editorial-outline {\n    @apply bg-transparent text-[var(--ink-black)] hover:bg-[var(--ink-black)] hover:text-white transition-colors duration-300;\n  }\n\n  .footnote-sup {\n    @apply text-[var(--royal-blue)] font-bold text-xs ml-0.5 cursor-help;\n  }\n\n  /* Grid Layout for Hero */\n  .hero-grid {\n    display: grid;\n    grid-template-columns: 2.2fr 1px 5.5fr 1px 2.2fr;\n    gap: 0;\n  }\n\n  @media (max-width: 1200px) {\n    .hero-grid {\n      grid-template-columns: 1fr;\n    }\n    .column-divider { border-left: 0; border-top: 1px solid var(--paper-line); }\n  }\n\n  /* Animation overrides to ensure no CSS/GSAP conflict */\n  .step-card, .card-editorial, .gauge-svg path {\n    transition: none !important;\n  }\n</style>\n\n<div id=\"main-wrapper\" class=\"paper-texture min-h-screen\" data-kid=\"7\">\n  \n  <nav class=\"fixed top-0 left-0 right-0 z-50 glass-nav px-8 h-20 flex items-center justify-between\" data-kid=\"8\">\n    <div class=\"flex items-center gap-6\" data-kid=\"9\">\n      <h2 class=\"text-2xl font-serif font-black tracking-tighter cursor-pointer\" data-kid=\"10\">THE GAZETTE</h2>\n      <div class=\"h-6 w-px bg-gray-300 hidden md:block\" data-kid=\"11\"></div>\n      <div class=\"hidden md:flex flex-col\" data-kid=\"12\">\n        <span class=\"text-[9px] font-black uppercase tracking-[0.3em] opacity-50\" data-kid=\"13\">Global Accountability Bureau</span>\n        <span class=\"text-[11px] font-bold uppercase tracking-[0.2em]\" data-kid=\"14\">Wednesday, July 8, 2026</span>\n      </div>\n    </div>\n    <div class=\"flex items-center gap-12\" data-kid=\"15\">\n      <div class=\"hidden lg:flex gap-10\" data-kid=\"16\">\n        <a href=\"#\" class=\"text-[11px] font-black uppercase tracking-[0.2em] hover:text-[var(--royal-blue)]\" data-kid=\"17\">Methodology</a>\n        <a href=\"#\" class=\"text-[11px] font-black uppercase tracking-[0.2em] hover:text-[var(--royal-blue)]\" data-kid=\"18\">Archives</a>\n      </div>\n      <button class=\"bg-[var(--ink-black)] text-white text-[11px] font-black uppercase tracking-[0.2em] px-8 py-3 rounded-none\" data-kid=\"19\">New Audit</button>\n    </div>\n  </nav>\n\n  \n  <section id=\"hero-section\" class=\"pt-40 pb-24 px-8 max-w-[1600px] mx-auto\" data-kid=\"20\">\n    \n    <div class=\"masthead-rule-thick mt-4\" data-kid=\"21\"></div>\n    <div class=\"flex flex-col md:flex-row justify-between items-center py-3 text-[12px] font-black uppercase tracking-[0.4em]\" data-kid=\"22\">\n      <span data-kid=\"23\">VOL. CLXVIII • NO. 45,921</span>\n      <span class=\"hidden md:block\" data-kid=\"24\">PRICE: EMPIRICAL TRUTH</span>\n      <span data-kid=\"25\">FINAL EDITION • GLOBAL RELEASE</span>\n    </div>\n    <div class=\"masthead-rule-thin mb-16\" data-kid=\"26\"></div>\n\n    <div class=\"hero-grid\" data-kid=\"27\">\n      \n      <div class=\"p-8 flex flex-col justify-between space-y-16\" data-kid=\"28\">\n        <div class=\"space-y-6\" data-kid=\"29\">\n          <span class=\"text-[12px] font-black uppercase tracking-[0.2em] text-[var(--brick-red)]\" data-kid=\"30\">Breaking Analysis</span>\n          <h3 class=\"text-3xl font-serif font-bold leading-tight underline decoration-2 underline-offset-8 cursor-pointer hover:text-[var(--royal-blue)] transition-colors\" data-kid=\"31\">The Erosion of Public Accountability</h3>\n          <p class=\"text-base leading-relaxed text-[var(--editorial-slate)] font-medium italic\" data-kid=\"32\">\"A clinical study of rhetorical drift in the current administration's economic policy.\"</p>\n        </div>\n        <div class=\"space-y-6\" data-kid=\"33\">\n          <span class=\"text-[12px] font-black uppercase tracking-[0.2em] opacity-50\" data-kid=\"34\">Editorial Board</span>\n          <h3 class=\"text-2xl font-serif font-bold leading-tight underline decoration-1 underline-offset-6 cursor-pointer hover:text-[var(--royal-blue)] transition-colors\" data-kid=\"35\">Radical Neutrality in Automated Journalism</h3>\n        </div>\n      </div>\n\n      \n      <div class=\"column-divider\" data-kid=\"36\"></div>\n\n      \n      <div class=\"px-12 py-10 text-center flex flex-col justify-center\" data-kid=\"37\">\n        <h1 class=\"text-[8vw] md:text-[145px] font-serif font-black tracking-tighter leading-[0.8] mb-10\" data-kid=\"38\">POLITICAL<br data-kid=\"39\">INTEGRITY</h1>\n        <p class=\"text-2xl md:text-3xl font-serif italic text-[var(--editorial-slate)] mb-16 max-w-3xl mx-auto leading-relaxed\" data-kid=\"40\">\n          \"A clinical instrument for the objective cross-examination of political discourse against the established empirical record.\"\n        </p>\n        <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto w-full\" data-kid=\"41\">\n          <button id=\"trigger-demo\" class=\"btn-editorial btn-editorial-primary flex items-center justify-center gap-4\" data-kid=\"42\">\n            Auditing Prime Minister\n            <i class=\"ti ti-scan text-xl\" data-kid=\"43\"></i>\n          </button>\n          <button class=\"btn-editorial btn-editorial-outline flex items-center justify-center gap-4\" data-kid=\"44\">\n            Upload Evidence\n            <i class=\"ti ti-upload text-xl\" data-kid=\"45\"></i>\n          </button>\n        </div>\n      </div>\n\n      \n      <div class=\"column-divider\" data-kid=\"46\"></div>\n\n      \n      <div class=\"p-8 flex flex-col justify-between\" data-kid=\"47\">\n        <div class=\"space-y-10\" data-kid=\"48\">\n          <div class=\"space-y-3\" data-kid=\"49\">\n            <span class=\"text-[11px] font-black uppercase tracking-[0.3em] opacity-40\" data-kid=\"50\">Technical Audit</span>\n            <div class=\"h-1 w-12 bg-[var(--ink-black)]\" data-kid=\"51\"></div>\n          </div>\n          <div class=\"space-y-3\" data-kid=\"52\">\n            <span class=\"text-[12px] font-black uppercase tracking-[0.2em] opacity-50\" data-kid=\"53\">System Status</span>\n            <div class=\"flex items-center gap-3\" data-kid=\"54\">\n              <span class=\"w-3 h-3 bg-emerald-500 animate-pulse\" data-kid=\"55\"></span>\n              <span class=\"text-sm font-black uppercase tracking-[0.15em]\" data-kid=\"56\">Oracle Live</span>\n            </div>\n          </div>\n          <div class=\"space-y-3\" data-kid=\"57\">\n            <span class=\"text-[12px] font-black uppercase tracking-[0.2em] opacity-50\" data-kid=\"58\">Records Indexed</span>\n            <p class=\"text-5xl font-serif font-black\" data-kid=\"59\">12.4M+</p>\n          </div>\n        </div>\n        <div class=\"pt-12 border-t-4 border-[var(--ink-black)]\" data-kid=\"60\">\n          <p class=\"text-xs font-serif italic leading-relaxed text-[var(--ink-black)] font-bold\" data-kid=\"61\">\n            \"Objective truth is not a consensus, but a rigorous elimination of rhetorical inconsistency.\"\n          </p>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"masthead-rule-thin mt-16\" data-kid=\"62\"></div>\n    \n    \n    <div class=\"flex flex-wrap justify-center gap-x-16 gap-y-6 py-10 opacity-60 grayscale\" data-kid=\"63\">\n      <span class=\"text-[11px] font-black uppercase tracking-[0.4em]\" data-kid=\"64\">KOSIS Archive Partner</span>\n      <span class=\"text-[11px] font-black uppercase tracking-[0.4em]\" data-kid=\"65\">IMF Data Custodian</span>\n      <span class=\"text-[11px] font-black uppercase tracking-[0.4em]\" data-kid=\"66\">OECD Statistics Hub</span>\n      <span class=\"text-[11px] font-black uppercase tracking-[0.4em]\" data-kid=\"67\">World Bank Affiliate</span>\n    </div>\n  </section>\n\n  \n  <section id=\"analysis-view\" class=\"py-32 bg-white/70 border-y-2 border-[var(--ink-black)] hidden\" data-kid=\"68\">\n    <div class=\"max-w-6xl mx-auto px-8\" data-kid=\"69\">\n      <div class=\"text-center space-y-6 mb-24\" data-kid=\"70\">\n        <span class=\"text-xs font-black uppercase tracking-[0.5em] text-[var(--royal-blue)]\" data-kid=\"71\">AUDIT ID: PM-2026-07-08A</span>\n        <h2 class=\"font-serif text-6xl italic leading-none\" data-kid=\"72\">The Printing Press in Motion</h2>\n        <p class=\"text-base opacity-60 font-black uppercase tracking-[0.3em]\" data-kid=\"73\">Phase: Clinical Assertive Examination</p>\n      </div>\n      \n      <div class=\"relative py-16\" data-kid=\"74\">\n        <div class=\"ink-fill-track w-full\" data-kid=\"75\">\n          <div id=\"progress-bar\" class=\"ink-fill-progress\" data-kid=\"76\"></div>\n        </div>\n        \n        <div class=\"flex justify-between relative -top-11\" data-kid=\"77\">\n          <div class=\"step-card flex flex-col items-center group opacity-20\" id=\"step-1\" data-kid=\"78\">\n            <div class=\"w-16 h-16 bg-white border-4 border-gray-200 flex items-center justify-center mb-6 group-[.active]:border-[var(--ink-black)] group-[.active]:bg-[var(--ink-black)] group-[.active]:text-white\" data-kid=\"79\">\n              <i class=\"ti ti-microphone text-3xl\" data-kid=\"80\"></i>\n            </div>\n            <span class=\"font-serif font-black text-base uppercase\" data-kid=\"81\">Transcription</span>\n          </div>\n          <div class=\"step-card flex flex-col items-center group opacity-20\" id=\"step-2\" data-kid=\"82\">\n            <div class=\"w-16 h-16 bg-white border-4 border-gray-200 flex items-center justify-center mb-6 group-[.active]:border-[var(--ink-black)] group-[.active]:bg-[var(--ink-black)] group-[.active]:text-white\" data-kid=\"83\">\n              <i class=\"ti ti-file-search text-3xl\" data-kid=\"84\"></i>\n            </div>\n            <span class=\"font-serif font-black text-base uppercase\" data-kid=\"85\">Extraction</span>\n          </div>\n          <div class=\"step-card flex flex-col items-center group opacity-20\" id=\"step-3\" data-kid=\"86\">\n            <div class=\"w-16 h-16 bg-white border-4 border-gray-200 flex items-center justify-center mb-6 group-[.active]:border-[var(--ink-black)] group-[.active]:bg-[var(--ink-black)] group-[.active]:text-white\" data-kid=\"87\">\n              <i class=\"ti ti-history text-3xl\" data-kid=\"88\"></i>\n            </div>\n            <span class=\"font-serif font-black text-base uppercase\" data-kid=\"89\">Integrity</span>\n          </div>\n          <div class=\"step-card flex flex-col items-center group opacity-20\" id=\"step-4\" data-kid=\"90\">\n            <div class=\"w-16 h-16 bg-white border-4 border-gray-200 flex items-center justify-center mb-6 group-[.active]:border-[var(--ink-black)] group-[.active]:bg-[var(--ink-black)] group-[.active]:text-white\" data-kid=\"91\">\n              <i class=\"ti ti-database-check text-3xl\" data-kid=\"92\"></i>\n            </div>\n            <span class=\"font-serif font-black text-base uppercase\" data-kid=\"93\">Verification</span>\n          </div>\n        </div>\n      </div>\n      \n      <div id=\"log-feed\" class=\"mt-24 max-w-2xl mx-auto p-10 bg-[var(--ink-black)] text-emerald-500 font-mono text-xs rounded-none border-t-[12px] border-gray-800 shadow-2xl\" data-kid=\"94\">\n        <div id=\"log-output\" class=\"h-48 overflow-y-auto space-y-2\" data-kid=\"95\">\n          <p class=\"opacity-50 tracking-widest\" data-kid=\"96\">> INITIALIZING MECHANICAL ARBITER...</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <main id=\"dashboard-view\" class=\"py-32 px-8 hidden\" data-kid=\"97\">\n    <div class=\"max-w-[1440px] mx-auto\" data-kid=\"98\">\n      \n      \n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 border-b-8 border-[var(--ink-black)] pb-20 mb-32 items-end\" data-kid=\"99\">\n        <div class=\"lg:col-span-6 space-y-12\" data-kid=\"100\">\n          <div class=\"flex items-center gap-6\" data-kid=\"101\">\n            <span class=\"px-6 py-2 bg-[var(--ink-black)] text-white text-[11px] font-black uppercase tracking-[0.4em]\" data-kid=\"102\">Official Report</span>\n            <span class=\"text-xs font-black opacity-50 uppercase tracking-[0.2em]\" data-kid=\"103\">Wednesday, 08 July 2026</span>\n          </div>\n          <h2 class=\"text-8xl font-serif font-black tracking-tighter leading-[0.85] italic\" data-kid=\"104\">The Desk Report:<br data-kid=\"105\"><span class=\"not-italic\" data-kid=\"106\">Prime Minister's Testimony</span></h2>\n          <p class=\"text-2xl leading-relaxed text-[var(--editorial-slate)] max-w-2xl font-serif italic\" data-kid=\"107\">\n            \"A comprehensive audit of the 24-minute address, cross-examining 18 assertions against archival record and empirical database nodes.\"\n          </p>\n          <div class=\"flex gap-20 pt-6\" data-kid=\"108\">\n            <div data-kid=\"109\">\n              <p class=\"text-[12px] font-black uppercase tracking-[0.3em] opacity-40 mb-3\" data-kid=\"110\">Assertions</p>\n              <p class=\"text-7xl font-serif font-black\" data-kid=\"111\">18</p>\n            </div>\n            <div data-kid=\"112\">\n              <p class=\"text-[12px] font-black uppercase tracking-[0.3em] opacity-40 mb-3 text-[var(--brick-red)]\" data-kid=\"113\">Conflicts</p>\n              <p class=\"text-7xl font-serif font-black text-[var(--brick-red)]\" data-kid=\"114\">05</p>\n            </div>\n            <div data-kid=\"115\">\n              <p class=\"text-[12px] font-black uppercase tracking-[0.3em] opacity-40 mb-3 text-[var(--brick-red)]\" data-kid=\"116\">Fact Fail</p>\n              <p class=\"text-7xl font-serif font-black text-[var(--brick-red)]\" data-kid=\"117\">03</p>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"lg:col-span-3 flex flex-col items-center justify-center space-y-12 border-x-0 lg:border-x-2 border-gray-200 px-12\" data-kid=\"118\">\n          <div class=\"relative\" data-kid=\"119\">\n            <svg width=\"260\" height=\"140\" viewBox=\"0 0 240 120\" class=\"gauge-svg\" data-kid=\"120\">\n              <path d=\"M10 120 A 110 110 0 0 1 230 120\" fill=\"none\" stroke=\"#f1f5f9\" stroke-width=\"22\" data-kid=\"121\"></path>\n              <path id=\"con-path\" d=\"M10 120 A 110 110 0 0 1 230 120\" fill=\"none\" stroke=\"var(--royal-blue)\" stroke-width=\"22\" stroke-dasharray=\"345.58\" stroke-dashoffset=\"345.58\" data-kid=\"122\"></path>\n            </svg>\n            <div class=\"absolute bottom-4 left-0 right-0 text-center\" data-kid=\"123\">\n              <span id=\"con-value\" class=\"text-6xl font-serif font-black\" data-kid=\"124\">0%</span>\n            </div>\n          </div>\n          <div class=\"text-center\" data-kid=\"125\">\n            <p class=\"text-xs font-black uppercase tracking-[0.4em]\" data-kid=\"126\">Integrity Score</p>\n            <p class=\"text-[11px] opacity-40 font-bold uppercase mt-3 tracking-widest\" data-kid=\"127\">Self-Consistency Record</p>\n          </div>\n        </div>\n\n        <div class=\"lg:col-span-3 flex flex-col items-center justify-center space-y-12\" data-kid=\"128\">\n          <div class=\"relative\" data-kid=\"129\">\n            <svg width=\"260\" height=\"140\" viewBox=\"0 0 240 120\" class=\"gauge-svg\" data-kid=\"130\">\n              <path d=\"M10 120 A 110 110 0 0 1 230 120\" fill=\"none\" stroke=\"#f1f5f9\" stroke-width=\"22\" data-kid=\"131\"></path>\n              <path id=\"fac-path\" d=\"M10 120 A 110 110 0 0 1 230 120\" fill=\"none\" stroke=\"var(--emerald-green)\" stroke-width=\"22\" stroke-dasharray=\"345.58\" stroke-dashoffset=\"345.58\" data-kid=\"132\"></path>\n            </svg>\n            <div class=\"absolute bottom-4 left-0 right-0 text-center\" data-kid=\"133\">\n              <span id=\"fac-value\" class=\"text-6xl font-serif font-black\" data-kid=\"134\">0%</span>\n            </div>\n          </div>\n          <div class=\"text-center\" data-kid=\"135\">\n            <p class=\"text-xs font-black uppercase tracking-[0.4em]\" data-kid=\"136\">Factuality Score</p>\n            <p class=\"text-[11px] opacity-40 font-bold uppercase mt-3 tracking-widest\" data-kid=\"137\">Empirical Database Audit</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div id=\"results-grid\" class=\"grid grid-cols-1 gap-16\" data-kid=\"138\">\n        \n        <div class=\"card-editorial p-12 md:p-20 overflow-hidden shadow-sm\" data-kid=\"139\">\n          <div class=\"verdict-line bg-[var(--brick-red)]\" data-kid=\"140\"></div>\n          <div class=\"flex flex-wrap justify-between items-start gap-12 mb-16\" data-kid=\"141\">\n            <div class=\"flex items-center gap-10\" data-kid=\"142\">\n              <span class=\"font-mono text-sm font-bold opacity-30 tracking-tighter\" data-kid=\"143\">NODE #03 • TS 01:24</span>\n              <div class=\"h-10 w-px bg-gray-200\" data-kid=\"144\"></div>\n              <div class=\"flex items-center gap-4 text-[var(--brick-red)] text-xs font-black uppercase tracking-[0.2em]\" data-kid=\"145\">\n                <i class=\"ti ti-alert-triangle text-2xl\" data-kid=\"146\"></i> CRITICAL INTEGRITY CONFLICT\n              </div>\n            </div>\n            <div class=\"flex gap-6\" data-kid=\"147\">\n              <span class=\"px-6 py-3 border-4 border-[var(--brick-red)] text-[var(--brick-red)] text-[11px] font-black uppercase tracking-[0.1em]\" data-kid=\"148\">Contradiction</span>\n              <span class=\"px-6 py-3 border-4 border-[var(--brick-red)] text-[var(--brick-red)] text-[11px] font-black uppercase tracking-[0.1em]\" data-kid=\"149\">Verdict: False</span>\n            </div>\n          </div>\n          \n          <h3 class=\"text-5xl md:text-[80px] font-serif font-bold leading-[0.9] max-w-6xl tracking-tight\" data-kid=\"150\">\n            “The youth unemployment rate has dropped to half of what it was under the previous administration.”<sup class=\"footnote-sup open-drawer\" data-target=\"e3\" data-kid=\"151\">1</sup>\n          </h3>\n\n          <div class=\"mt-20 pt-12 border-t-2 border-gray-100 flex flex-wrap items-center justify-between gap-12\" data-kid=\"152\">\n            <div class=\"flex items-center gap-16 text-xs font-black uppercase tracking-[0.2em] opacity-60\" data-kid=\"153\">\n              <div class=\"flex items-center gap-4\" data-kid=\"154\"><i class=\"ti ti-history text-2xl\" data-kid=\"155\"></i> Direct Archive Discrepancy (2025)</div>\n              <div class=\"flex items-center gap-4\" data-kid=\"156\"><i class=\"ti ti-database text-2xl\" data-kid=\"157\"></i> KOSIS National Database Source</div>\n            </div>\n            <button class=\"open-drawer flex items-center gap-6 text-[11px] font-black uppercase tracking-[0.4em] hover:text-[var(--royal-blue)] transition-colors group\" data-target=\"e3\" data-kid=\"158\">\n              Inspect Evidence <i class=\"ti ti-arrow-narrow-right text-3xl group-hover:translate-x-4 transition-transform duration-500\" data-kid=\"159\"></i>\n            </button>\n          </div>\n        </div>\n\n        \n        <div class=\"card-editorial p-12 md:p-20 overflow-hidden shadow-sm\" data-kid=\"160\">\n          <div class=\"verdict-line bg-[var(--mustard-yellow)]\" data-kid=\"161\"></div>\n          <div class=\"flex flex-wrap justify-between items-start gap-12 mb-16\" data-kid=\"162\">\n            <div class=\"flex items-center gap-10\" data-kid=\"163\">\n              <span class=\"font-mono text-sm font-bold opacity-30 tracking-tighter\" data-kid=\"164\">NODE #04 • TS 02:10</span>\n              <div class=\"h-10 w-px bg-gray-200\" data-kid=\"165\"></div>\n              <div class=\"flex items-center gap-4 text-[var(--mustard-yellow)] text-xs font-black uppercase tracking-[0.2em]\" data-kid=\"166\">\n                <i class=\"ti ti-help-circle text-2xl\" data-kid=\"167\"></i> CONTEXTUAL AMBIGUITY\n              </div>\n            </div>\n            <div class=\"flex gap-6\" data-kid=\"168\">\n              <span class=\"px-6 py-3 border-4 border-gray-200 text-gray-400 text-[11px] font-black uppercase tracking-[0.1em]\" data-kid=\"169\">Insufficient Data</span>\n              <span class=\"px-6 py-3 border-4 border-[var(--mustard-yellow)] text-[var(--mustard-yellow)] text-[11px] font-black uppercase tracking-[0.1em]\" data-kid=\"170\">Unverifiable</span>\n            </div>\n          </div>\n          \n          <h3 class=\"text-5xl md:text-[80px] font-serif font-bold leading-[0.9] max-w-6xl tracking-tight\" data-kid=\"171\">\n            “Our investment in regional infrastructure exceeds that of any neighboring state in the last decade.”<sup class=\"footnote-sup open-drawer\" data-target=\"e4\" data-kid=\"172\">2</sup>\n          </h3>\n\n          <div class=\"mt-20 pt-12 border-t-2 border-gray-100 flex flex-wrap items-center justify-between gap-12\" data-kid=\"173\">\n            <div class=\"flex items-center gap-16 text-xs font-black uppercase tracking-[0.2em] opacity-60\" data-kid=\"174\">\n              <div class=\"flex items-center gap-4\" data-kid=\"175\"><i class=\"ti ti-circle-x text-2xl\" data-kid=\"176\"></i> No Conflicting Record Found</div>\n              <div class=\"flex items-center gap-4\" data-kid=\"177\"><i class=\"ti ti-world text-2xl\" data-kid=\"178\"></i> Comparative Repositories Queried</div>\n            </div>\n            <button class=\"open-drawer flex items-center gap-6 text-[11px] font-black uppercase tracking-[0.4em] hover:text-[var(--royal-blue)] transition-colors group\" data-target=\"e4\" data-kid=\"179\">\n              Inspect Evidence <i class=\"ti ti-arrow-narrow-right text-3xl group-hover:translate-x-4 transition-transform duration-500\" data-kid=\"180\"></i>\n            </button>\n          </div>\n        </div>\n      </div>\n\n      \n      <footer class=\"mt-48 pt-24 border-t-8 border-[var(--ink-black)] flex flex-col md:flex-row justify-between gap-24\" data-kid=\"181\">\n        <div class=\"max-w-xl space-y-10\" data-kid=\"182\">\n          <h4 class=\"font-serif font-black text-4xl italic\" data-kid=\"183\">The Editorial Charter</h4>\n          <p class=\"text-lg leading-relaxed text-[var(--editorial-slate)] font-serif italic font-medium\" data-kid=\"184\">\n            \"Objective truth is an empirical constant. This instrument cross-examines declarations against a mathematical record of factual data and historical transcript. We do not assess politics; we assess alignment.\"\n          </p>\n        </div>\n        <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-16 text-xs font-black uppercase tracking-[0.3em]\" data-kid=\"185\">\n          <div class=\"flex flex-col gap-6\" data-kid=\"186\">\n            <a href=\"#\" class=\"hover:underline underline-offset-8\" data-kid=\"187\">Methodology Whitepaper</a>\n            <a href=\"#\" class=\"hover:underline underline-offset-8\" data-kid=\"188\">Primary Source Audit</a>\n            <a href=\"#\" class=\"hover:underline underline-offset-8\" data-kid=\"189\">Algorithm Transparency</a>\n          </div>\n          <div class=\"flex flex-col gap-6\" data-kid=\"190\">\n            <a href=\"#\" class=\"hover:underline underline-offset-8\" data-kid=\"191\">Ethics Board</a>\n            <a href=\"#\" class=\"hover:underline underline-offset-8\" data-kid=\"192\">Conflict Protocol</a>\n            <a href=\"#\" class=\"hover:underline underline-offset-8\" data-kid=\"193\">Archive Integrity</a>\n          </div>\n        </div>\n      </footer>\n    </div>\n  </main>\n\n  \n  <aside id=\"drawer\" class=\"evidence-drawer\" data-kid=\"194\">\n    <div class=\"p-12 border-b-4 border-[var(--ink-black)] flex items-center justify-between\" data-kid=\"195\">\n      <div class=\"space-y-2\" data-kid=\"196\">\n        <h3 class=\"font-serif font-black text-4xl italic\" data-kid=\"197\">Source Audit</h3>\n        <p class=\"text-[11px] font-black uppercase tracking-[0.4em] opacity-40\" data-kid=\"198\">Analytical Empirical Evidence</p>\n      </div>\n      <button id=\"close-drawer\" class=\"w-16 h-16 border-2 border-[var(--ink-black)] flex items-center justify-center hover:bg-black hover:text-white transition-colors duration-300\" data-kid=\"199\">\n        <i class=\"ti ti-x text-3xl\" data-kid=\"200\"></i>\n      </button>\n    </div>\n\n    <div class=\"flex-1 overflow-y-auto p-12 space-y-24\" data-kid=\"201\">\n      \n      <div id=\"e3-detail\" class=\"evidence-panel hidden space-y-16\" data-kid=\"202\">\n        <div class=\"space-y-6\" data-kid=\"203\">\n          <label class=\"text-xs font-black uppercase tracking-[0.5em] opacity-40\" data-kid=\"204\">Assertion Node</label>\n          <p class=\"font-serif text-4xl font-bold leading-tight text-[var(--editorial-slate)] italic\" data-kid=\"205\">“The youth unemployment rate has dropped to half of what it was under the previous administration.”</p>\n        </div>\n\n        <div class=\"p-12 border-4 border-[var(--ink-black)] space-y-10 shadow-xl bg-white\" data-kid=\"206\">\n          <div class=\"flex items-center gap-6 text-[var(--brick-red)] font-black text-sm uppercase tracking-[0.2em]\" data-kid=\"207\">\n            <i class=\"ti ti-history text-3xl\" data-kid=\"208\"></i> Direct Record Discrepancy\n          </div>\n          <div class=\"space-y-6\" data-kid=\"209\">\n            <p class=\"text-[11px] uppercase font-black opacity-40 tracking-widest\" data-kid=\"210\">Previous Statement • National Forum Transcript (Nov 2025)</p>\n            <p class=\"text-xl font-medium leading-relaxed italic text-[var(--ink-black)]\" data-kid=\"211\">“While current measures show promise, youth employment remains the most stagnant sector of our labor market since the 2022 pivot.”</p>\n            <div class=\"pt-4\" data-kid=\"212\">\n              <a href=\"#\" class=\"text-xs font-black uppercase tracking-[0.3em] text-[var(--royal-blue)] underline underline-offset-8\" data-kid=\"213\">Primary Archive: BR-991</a>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"p-12 border-4 border-[var(--ink-black)] space-y-10 shadow-xl bg-white\" data-kid=\"214\">\n          <div class=\"flex items-center gap-6 text-[var(--brick-red)] font-black text-sm uppercase tracking-[0.2em]\" data-kid=\"215\">\n            <i class=\"ti ti-database text-3xl\" data-kid=\"216\"></i> Empirical Misalignment\n          </div>\n          <div class=\"space-y-8\" data-kid=\"217\">\n            <p class=\"text-[11px] uppercase font-black opacity-40 tracking-widest\" data-kid=\"218\">Database: KOSIS Central Registry Q2 2026</p>\n            <p class=\"text-lg leading-relaxed font-medium\" data-kid=\"219\">Statistical reports from the National Registry (KOSIS) contradict the Prime Minister's claim. Official delta is recorded at -1.2%, failing to match the asserted -4.9% (half-point reduction).</p>\n            <div class=\"space-y-6 pt-6\" data-kid=\"220\">\n              <div class=\"flex justify-between text-xs font-black uppercase tracking-[0.4em]\" data-kid=\"221\">\n                <span data-kid=\"222\">Actual Empirical Delta</span>\n                <span class=\"text-[var(--brick-red)]\" data-kid=\"223\">-1.2%</span>\n              </div>\n              <div class=\"h-6 w-full bg-gray-100\" data-kid=\"224\">\n                <div class=\"h-full bg-[var(--brick-red)] w-[12%]\" data-kid=\"225\"></div>\n              </div>\n              <p class=\"text-[10px] text-right opacity-40 tracking-widest\" data-kid=\"226\">Database Confidence: 99.98% Parity</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div id=\"e4-detail\" class=\"evidence-panel hidden space-y-16\" data-kid=\"227\">\n        <div class=\"space-y-6\" data-kid=\"228\">\n          <label class=\"text-xs font-black uppercase tracking-[0.5em] opacity-40\" data-kid=\"229\">Assertion Node</label>\n          <p class=\"font-serif text-4xl font-bold leading-tight text-[var(--editorial-slate)] italic\" data-kid=\"230\">“Our investment in regional infrastructure exceeds that of any neighboring state in the last decade.”</p>\n        </div>\n\n        <div class=\"p-12 border-4 border-[var(--ink-black)] space-y-10 bg-white\" data-kid=\"231\">\n          <div class=\"flex items-center gap-6 text-[var(--mustard-yellow)] font-black text-sm uppercase tracking-[0.2em]\" data-kid=\"232\">\n            <i class=\"ti ti-world text-3xl\" data-kid=\"233\"></i> Status: Unverifiable\n          </div>\n          <div class=\"space-y-8\" data-kid=\"234\">\n            <p class=\"text-lg leading-relaxed font-medium text-[var(--editorial-slate)]\" data-kid=\"235\">\n              Cross-border infrastructure capital parity cannot be empirically determined due to misaligned reporting cycles and non-standardized fiscal definitions across regional partners.\n            </p>\n            <ul class=\"text-xs font-black uppercase tracking-[0.3em] space-y-6 opacity-80 list-none pl-0\" data-kid=\"236\">\n              <li class=\"flex items-center gap-6\" data-kid=\"237\"><i class=\"ti ti-circle-x text-xl\" data-kid=\"238\"></i> State A cycle closure: 2027</li>\n              <li class=\"flex items-center gap-6\" data-kid=\"239\"><i class=\"ti ti-circle-x text-xl\" data-kid=\"240\"></i> State B excludes rural capital spend</li>\n              <li class=\"flex items-center gap-6\" data-kid=\"241\"><i class=\"ti ti-circle-x text-xl\" data-kid=\"242\"></i> Regional parity metrics absent</li>\n            </ul>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"p-12 border-t-8 border-[var(--ink-black)] bg-white\" data-kid=\"243\">\n      <div class=\"flex gap-10\" data-kid=\"244\">\n        <i class=\"ti ti-alert-circle text-4xl text-[var(--brick-red)]\" data-kid=\"245\"></i>\n        <div class=\"space-y-3\" data-kid=\"246\">\n          <p class=\"text-base font-serif font-black italic\" data-kid=\"247\">Scholarly Editorial Notice</p>\n          <p class=\"text-xs leading-relaxed text-[var(--editorial-slate)] font-medium\" data-kid=\"248\">\n            This analytical report was generated by Oracle AI Engine under Editorial Bureau supervision. Final journalistic dissemination requires secondary human empirical verification.\n          </p>\n        </div>\n      </div>\n    </div>\n  </aside>\n\n  \n  <div id=\"overlay\" class=\"fixed inset-0 bg-black/90 z-[90] hidden backdrop-blur-xl opacity-0\" data-kid=\"249\"></div>\n</div>\n\n<script data-kid=\"250\">\n  // Elements\n  const heroSection = document.getElementById('hero-section');\n  const analysisView = document.getElementById('analysis-view');\n  const dashboardView = document.getElementById('dashboard-view');\n  const triggerBtn = document.getElementById('trigger-demo');\n  const progressBar = document.getElementById('progress-bar');\n  const logOutput = document.getElementById('log-output');\n  const drawer = document.getElementById('drawer');\n  const overlay = document.getElementById('overlay');\n  const closeDrawerBtn = document.getElementById('close-drawer');\n\n  // Logs\n  const logMessages = [\n    \"ATTACHING CLINICAL PROBE...\",\n    \"SIGNAL FILTERING: INITIATED (24:12)...\",\n    \"NODE EXTRACTION: 18 FACTUAL ASSERTIONS...\",\n    \"CROSS-REFERENCING HISTORICAL TRANSCRIPTS...\",\n    \"CONFLICT DETECTED: NODE #03 (INTEGRITY)...\",\n    \"POLLING KOSIS DATABASE (API-SYNC)...\",\n    \"DATA PARITY MISMATCH: -1.2% VS -4.9% (FAIL)\",\n    \"AUDITING REGIONAL REPOSITORIES...\",\n    \"NODE #04 STATUS: EMPIRICAL UNVERIFIABILITY...\",\n    \"SYNTHESIZING MECHANICAL VERDICTS...\"\n  ];\n\n  function runLogs(onComplete) {\n    let index = 0;\n    const interval = setInterval(() => {\n      if (index >= logMessages.length) {\n        clearInterval(interval);\n        onComplete();\n        return;\n      }\n      const p = document.createElement('p');\n      p.className = \"mb-2 text-emerald-400 opacity-0 tracking-widest\";\n      p.innerText = \"> \" + logMessages[index];\n      logOutput.appendChild(p);\n      gsap.to(p, { opacity: 1, duration: 0.1 });\n      logOutput.scrollTop = logOutput.scrollHeight;\n      index++;\n    }, 400);\n  }\n\n  // Sequences\n  triggerBtn.addEventListener('click', () => {\n    gsap.to(heroSection, { opacity: 0, y: -50, duration: 0.8, onComplete: () => {\n      heroSection.classList.add('hidden');\n      analysisView.classList.remove('hidden');\n      gsap.from(analysisView, { opacity: 0, y: 50, duration: 0.8 });\n      startAnalysisSequence();\n    }});\n  });\n\n  function startAnalysisSequence() {\n    const tl = gsap.timeline();\n    tl.to(progressBar, { width: \"100%\", duration: 6, ease: \"none\" });\n    \n    const steps = ['#step-1', '#step-2', '#step-3', '#step-4'];\n    steps.forEach((step, i) => {\n      tl.to(step, { opacity: 1, duration: 0.4, onStart: () => {\n        document.querySelector(step).classList.add('active');\n      }}, (i * 1.5));\n    });\n\n    runLogs(() => {\n      setTimeout(() => {\n        gsap.to(analysisView, { opacity: 0, y: -50, duration: 0.8, onComplete: () => {\n          analysisView.classList.add('hidden');\n          dashboardView.classList.remove('hidden');\n          gsap.from(dashboardView, { opacity: 0, y: 50, duration: 0.8 });\n          animateDashboard();\n        }});\n      }, 1000);\n    });\n  }\n\n  function animateDashboard() {\n    // Path lengths are roughly 314.16 for a semi-circle of radius 100\n    // For radius 110, length is ~345.58\n    gsap.to(\"#con-path\", { strokeDashoffset: 96, duration: 3, ease: \"power4.out\", delay: 0.5 });\n    gsap.to(\"#fac-path\", { strokeDashoffset: 124, duration: 3, ease: \"power4.out\", delay: 0.8 });\n    \n    let conVal = { v: 0 };\n    gsap.to(conVal, { v: 72, duration: 3, delay: 0.5, onUpdate: () => {\n      document.getElementById('con-value').innerText = Math.round(conVal.v) + \"%\";\n    }});\n    \n    let facVal = { v: 0 };\n    gsap.to(facVal, { v: 64, duration: 3, delay: 0.8, onUpdate: () => {\n      document.getElementById('fac-value').innerText = Math.round(facVal.v) + \"%\";\n    }});\n\n    gsap.from(\".card-editorial\", {\n      opacity: 0,\n      y: 80,\n      duration: 1.2,\n      stagger: 0.3,\n      ease: \"power3.out\",\n      delay: 1\n    });\n  }\n\n  // Drawer\n  const openEvidence = (id) => {\n    document.querySelectorAll('.evidence-panel').forEach(p => p.classList.add('hidden'));\n    const p = document.getElementById(id + '-detail');\n    if (p) p.classList.remove('hidden');\n    \n    overlay.classList.remove('hidden');\n    gsap.to(overlay, { opacity: 1, duration: 0.4 });\n    gsap.to(drawer, { right: 0, duration: 0.8, ease: \"power4.out\" });\n  };\n\n  const closeEvidence = () => {\n    gsap.to(drawer, { right: \"-100%\", duration: 0.6, ease: \"power4.in\" });\n    gsap.to(overlay, { opacity: 0, duration: 0.5, onComplete: () => overlay.classList.add('hidden') });\n  };\n\n  document.querySelectorAll('.open-drawer').forEach(el => {\n    el.addEventListener('click', (e) => {\n      e.preventDefault();\n      openEvidence(el.dataset.target);\n    });\n  });\n\n  closeDrawerBtn.addEventListener('click', closeEvidence);\n  overlay.addEventListener('click', closeEvidence);\n\n  // Initial Logic\n  document.querySelectorAll('.btn-editorial').forEach(btn => {\n    btn.addEventListener('mousedown', () => gsap.to(btn, { scale: 0.98, duration: 0.1 }));\n    btn.addEventListener('mouseup', () => gsap.to(btn, { scale: 1, duration: 0.1 }));\n  });\n\n</script>\n",
