      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap');\n\n  :root {\n    --navy: #0F172A;\n    --blue: #2563EB;\n    --green: #16A34A;\n    --orange: #EA580C;\n    --red: #DC2626;\n    --slate: #F8FAFC;\n    --gray: #64748B;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: #FFFFFF;\n    color: var(--navy);\n    margin: 0;\n    padding: 0;\n  }\n\n  .font-mono {\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  .blueprint-grid {\n    background-image: \n      linear-gradient(to right, rgba(15, 23, 42, 0.05) 1px, transparent 1px),\n      linear-gradient(to bottom, rgba(15, 23, 42, 0.05) 1px, transparent 1px);\n    background-size: 40px 40px;\n  }\n\n  .sharp-shadow {\n    box-shadow: 8px 8px 0px 0px #0F172A;\n  }\n\n  .sharp-shadow-sm {\n    box-shadow: 4px 4px 0px 0px #0F172A;\n  }\n\n  .btn-primary {\n    background-color: #0F172A;\n    color: #FFFFFF;\n    padding: 1rem 2rem;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    border: none;\n    transition: all 0.2s ease;\n    cursor: pointer;\n  }\n\n  .btn-primary:hover {\n    background-color: #1D4ED8;\n    box-shadow: none;\n    transform: translate(2px, 2px);\n  }\n\n  .btn-secondary {\n    border: 1px solid #0F172A;\n    color: #0F172A;\n    padding: 1rem 2rem;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    background: transparent;\n    cursor: pointer;\n    box-shadow: 4px 4px 0px 0px #0F172A;\n  }\n\n  .btn-secondary:hover {\n    background-color: #F8FAFC;\n    box-shadow: none;\n    transform: translate(2px, 2px);\n  }\n\n  /* Custom segmented bar */\n  .segment-bar div {\n    height: 100%;\n    flex: 1;\n    border-right: 1px solid white;\n  }\n  .segment-bar div:last-child {\n    border-right: none;\n  }\n\n  .terminal-pulse {\n    animation: pulse 1.5s infinite;\n  }\n\n  @keyframes pulse {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0.3; }\n  }\n\n  .statement-card:hover {\n    background-color: #F8FAFC;\n    border-color: #2563EB;\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(100%); }\n    100% { transform: translateX(-100%); }\n  }\n  .animate-marquee {\n    animation: marquee 20s linear infinite;\n  }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n\n<div class=\"min-h-screen blueprint-grid\" data-kid=\"2\">\n  \n  <header class=\"border-b border-[#0F172A] bg-white sticky top-0 z-50\" data-kid=\"3\">\n    <div class=\"max-w-[1440px] mx-auto px-8 h-20 flex items-center justify-between\" data-kid=\"4\">\n      <div class=\"flex items-center gap-4\" data-kid=\"5\">\n        <div class=\"w-10 h-10 bg-[#0F172A] flex items-center justify-center\" data-kid=\"6\">\n            <i class=\"ti ti-git-merge text-white text-2xl\" data-kid=\"7\"></i>\n        </div>\n        <div data-kid=\"8\">\n            <p class=\"font-bold text-lg leading-none uppercase tracking-tighter\" data-kid=\"9\">Political Statement</p>\n            <p class=\"font-mono text-[10px] text-[#64748B] uppercase mt-1\" data-kid=\"10\">Contradiction_Detector_v1.0</p>\n        </div>\n      </div>\n      <nav class=\"hidden lg:flex gap-8\" data-kid=\"11\">\n        <div class=\"flex items-center gap-2 border-r border-[#0F172A]/10 pr-8\" data-kid=\"12\">\n            <span class=\"font-mono text-[10px] text-[#64748B] uppercase\" data-kid=\"13\">Recent:</span>\n            <div class=\"overflow-hidden w-64 h-4 relative\" data-kid=\"14\">\n                <div class=\"absolute whitespace-nowrap animate-marquee font-mono text-[10px] text-[#0F172A] font-bold uppercase\" data-kid=\"15\">\n                    [MATCH_FOUND] Y.S.Y. SEMICONDUCTOR_EXPORTS_Q2 // [CONTRADICTION] H.D.H. TAX_REFORM_DEBATE // \n                </div>\n            </div>\n        </div>\n        <a href=\"#\" class=\"font-bold uppercase text-[10px] tracking-widest hover:text-[#2563EB]\" data-kid=\"16\">Methodology</a>\n        <a href=\"#\" class=\"font-bold uppercase text-[10px] tracking-widest hover:text-[#2563EB]\" data-kid=\"17\">Data Sources</a>\n        <a href=\"#\" class=\"font-bold uppercase text-[10px] tracking-widest hover:text-[#2563EB]\" data-kid=\"18\">Public API</a>\n      </nav>\n      <div class=\"flex items-center gap-4\" data-kid=\"19\">\n        <span class=\"font-mono text-[10px] text-[#64748B] uppercase\" data-kid=\"20\">System Status: <span class=\"text-[#16A34A]\" data-kid=\"21\">LINK_STABLE</span></span>\n        <div class=\"w-2 h-2 bg-[#16A34A] shadow-[0_0_8px_rgba(22,163,74,0.5)]\" data-kid=\"22\"></div>\n      </div>\n    </div>\n  </header>\n\n  <main class=\"max-w-[1440px] mx-auto\" data-kid=\"23\">\n    \n    <section class=\"grid grid-cols-1 lg:grid-cols-2 border-b border-[#0F172A] min-h-[700px]\" data-kid=\"24\">\n      <div class=\"p-12 lg:p-24 flex flex-col justify-center border-r border-[#0F172A] bg-white\" data-kid=\"25\">\n        <div class=\"inline-block border border-[#0F172A] px-3 py-1 mb-8 font-mono text-xs tracking-tight\" data-kid=\"26\">\n          [ AUTH_LEVEL: PUBLIC_RESEARCH_DESK ]\n        </div>\n        <h1 class=\"text-7xl font-extrabold leading-[0.9] mb-8 uppercase tracking-tighter\" data-kid=\"27\">\n          Verification<br data-kid=\"28\">\n          <span class=\"text-[#2563EB]\" data-kid=\"29\">Through</span><br data-kid=\"30\">\n          Precision\n        </h1>\n        <p class=\"text-xl text-[#64748B] mb-12 max-w-lg leading-relaxed\" data-kid=\"31\">\n          An industrial-grade analytical tool designed for journalists. We decompose political statements into two distinct axes: <span class=\"text-[#0F172A] font-bold underline decoration-[#2563EB]\" data-kid=\"32\">Self-Consistency</span> (Historical match) and <span class=\"text-[#0F172A] font-bold underline decoration-[#16A34A]\" data-kid=\"33\">External Factuality</span> (Statistical validation).\n        </p>\n        <div class=\"flex flex-wrap gap-4\" data-kid=\"34\">\n          <button class=\"btn-primary shadow-[4px_4px_0px_0px_#0F172A]\" onclick=\"scrollToAnalysis()\" data-kid=\"35\">Start Verification</button>\n          <button class=\"btn-secondary\" data-kid=\"36\">Technical Specs</button>\n        </div>\n      </div>\n\n      <div class=\"bg-[#F8FAFC] relative flex items-center justify-center p-12 overflow-hidden\" data-kid=\"37\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/square.svg\" class=\"absolute inset-0 w-full h-full opacity-[0.03] p-10\" data-kid=\"38\">\n        \n        <div class=\"relative z-10 w-full max-w-xl\" data-kid=\"39\">\n            \n            <div class=\"border-2 border-[#0F172A] p-16 bg-white sharp-shadow relative\" data-kid=\"40\">\n                <div class=\"absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none\" style=\"background-image: repeating-linear-gradient(0deg, #0F172A 0, #0F172A 1px, transparent 1px, transparent 40px), repeating-linear-gradient(90deg, #0F172A 0, #0F172A 1px, transparent 1px, transparent 40px);\" data-kid=\"41\"></div>\n                \n                <div class=\"absolute -top-4 -left-4 bg-[#0F172A] text-white px-3 py-1 font-mono text-[10px] uppercase\" data-kid=\"42\">ANALYSIS_TOPOLOGY_V2</div>\n                <div class=\"absolute -bottom-4 -right-4 bg-[#2563EB] text-white px-3 py-1 font-mono text-[10px] uppercase\" data-kid=\"43\">COORD_X: 124.5 // Y: 08.2</div>\n                \n                <div class=\"text-center mb-16 relative\" data-kid=\"44\">\n                    <div class=\"inline-block border-2 border-[#0F172A] p-8 bg-white shadow-[8px_8px_0px_0px_rgba(15,23,42,1)]\" data-kid=\"45\">\n                        <p class=\"font-mono text-[10px] mb-3 text-[#64748B] uppercase tracking-widest\" data-kid=\"46\">Target_Claim_Segment</p>\n                        <p class=\"font-bold text-xl leading-tight uppercase tracking-tight\" data-kid=\"47\">\"Youth unemployment is lower<br data-kid=\"48\">than the previous administration.\"</p>\n                    </div>\n                    \n                    <div class=\"absolute top-full left-1/2 w-[2px] h-12 bg-[#0F172A] -translate-x-1/2\" data-kid=\"49\"></div>\n                </div>\n\n                <div class=\"grid grid-cols-2 gap-16 relative mt-12\" data-kid=\"50\">\n                    <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-full h-[1px] bg-[#0F172A]/20\" data-kid=\"51\"></div>\n                    \n                    <div class=\"flex flex-col items-end text-right space-y-6 relative\" data-kid=\"52\">\n                        <div class=\"absolute -top-1 w-3 h-3 bg-[#2563EB] -right-[6.5px]\" data-kid=\"53\"></div>\n                        <i class=\"ti ti-git-compare text-[#2563EB] text-4xl\" data-kid=\"54\"></i>\n                        <div data-kid=\"55\">\n                            <h3 class=\"font-black uppercase tracking-widest text-[#2563EB] text-sm mb-1\" data-kid=\"56\">Consistency Axis</h3>\n                            <p class=\"text-[10px] font-mono text-[#64748B] uppercase\" data-kid=\"57\">Historical database<br data-kid=\"58\">cross-reference</p>\n                        </div>\n                        <div class=\"border border-[#2563EB] p-4 bg-[#2563EB]/5 text-[#2563EB] font-mono text-[10px] uppercase w-full\" data-kid=\"59\">\n                            [ SEARCHING_ARCHIVE... ]\n                        </div>\n                    </div>\n                    \n                    <div class=\"flex flex-col items-start text-left space-y-6 relative\" data-kid=\"60\">\n                        <div class=\"absolute -top-1 w-3 h-3 bg-[#16A34A] -left-[6.5px]\" data-kid=\"61\"></div>\n                        <i class=\"ti ti-circle-check text-[#16A34A] text-4xl\" data-kid=\"62\"></i>\n                        <div data-kid=\"63\">\n                            <h3 class=\"font-black uppercase tracking-widest text-[#16A34A] text-sm mb-1\" data-kid=\"64\">Factuality Axis</h3>\n                            <p class=\"text-[10px] font-mono text-[#64748B] uppercase\" data-kid=\"65\">External statistical<br data-kid=\"66\">validation engine</p>\n                        </div>\n                        <div class=\"border border-[#16A34A] p-4 bg-[#16A34A]/5 text-[#16A34A] font-mono text-[10px] uppercase w-full\" data-kid=\"67\">\n                            [ STATUS: IDLE ]\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"analysis-panel\" class=\"p-12 lg:p-24 border-b border-[#0F172A] bg-white\" data-kid=\"68\">\n        <div class=\"max-w-5xl mx-auto\" data-kid=\"69\">\n            <div class=\"flex justify-between items-end mb-12\" data-kid=\"70\">\n                <div data-kid=\"71\">\n                    <h2 class=\"text-4xl font-black uppercase tracking-tighter\" data-kid=\"72\">Evidence Intake</h2>\n                    <p class=\"font-mono text-xs text-[#64748B] mt-2\" data-kid=\"73\">UPLOADER_MODULE // STT_CONVERTER</p>\n                </div>\n                <div class=\"hidden md:block\" data-kid=\"74\">\n                    <span class=\"font-mono text-xs text-[#64748B] uppercase\" data-kid=\"75\">Max File Size: 500MB</span>\n                </div>\n            </div>\n\n            <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch\" data-kid=\"76\">\n                \n                <div class=\"border-2 border-[#0F172A] p-1 bg-[#0F172A] shadow-[8px_8px_0px_0px_rgba(15,23,42,1)]\" data-kid=\"77\">\n                    <div class=\"bg-[#FFFFFF] p-12 border border-[#0F172A] border-dashed flex flex-col items-center justify-center text-center group cursor-pointer hover:bg-[#F8FAFC] transition-colors h-full min-h-[460px]\" data-kid=\"78\">\n                        <div class=\"w-20 h-20 border border-[#0F172A] mb-6 flex items-center justify-center relative\" data-kid=\"79\">\n                            <i class=\"ti ti-file-upload text-3xl text-[#0F172A] group-hover:scale-110 transition-transform\" data-kid=\"80\"></i>\n                            <div class=\"absolute -top-2 -right-2 w-4 h-4 bg-[#2563EB]\" data-kid=\"81\"></div>\n                        </div>\n                        <h3 class=\"font-black uppercase mb-2 tracking-widest\" data-kid=\"82\">Video / Audio Dossier</h3>\n                        <p class=\"text-xs text-[#64748B] font-mono px-12 leading-loose\" data-kid=\"83\">\n                            Drop evidence file for AI-assisted transcription.<br data-kid=\"84\">\n                            <span class=\"text-[#0F172A] opacity-40 font-bold\" data-kid=\"85\">[ MP4 / MOV / WAV / MP3 ]</span>\n                        </p>\n                        <button class=\"mt-8 bg-[#0F172A] text-white px-8 py-4 font-bold text-xs uppercase tracking-widest hover:bg-[#2563EB] transition-all shadow-[4px_4px_0px_0px_rgba(15,23,42,1)]\" data-kid=\"86\">Select Archive</button>\n                    </div>\n                </div>\n\n                \n                <div class=\"flex flex-col h-full min-h-[460px]\" data-kid=\"87\">\n                    <div class=\"flex gap-2 mb-4\" data-kid=\"88\">\n                        <button class=\"px-6 py-4 bg-[#0F172A] text-white font-bold text-[10px] uppercase tracking-widest shadow-[4px_4px_0px_0px_#0F172A]\" data-kid=\"89\">Manual_Entry</button>\n                        <button class=\"px-6 py-4 border border-[#0F172A] bg-white text-[#0F172A] font-bold text-[10px] uppercase tracking-widest opacity-40 hover:opacity-100 transition-opacity shadow-[4px_4px_0px_0px_#0F172A]\" data-kid=\"90\">Source_Link</button>\n                    </div>\n                    <div class=\"flex-grow border border-[#0F172A] bg-[#F8FAFC]/30 p-1\" data-kid=\"91\">\n                        <textarea class=\"w-full h-full bg-white border border-[#0F172A] p-6 font-mono text-sm focus:outline-hidden resize-none\" placeholder=\"Enter transcript text for claim decomposition...\" data-kid=\"92\"></textarea>\n                    </div>\n                    <div class=\"mt-6 flex flex-wrap gap-4\" data-kid=\"93\">\n                        <div class=\"flex-grow border border-[#0F172A] bg-white px-6 py-4 flex items-center justify-between\" data-kid=\"94\">\n                            <span class=\"text-[10px] font-mono text-[#64748B] uppercase tracking-widest\" data-kid=\"95\">Target_Subject</span>\n                            <select class=\"bg-transparent font-black text-xs uppercase outline-hidden cursor-pointer\" data-kid=\"96\">\n                                <option data-kid=\"97\">Lee Jae-myung</option>\n                                <option data-kid=\"98\">Han Dong-hoon</option>\n                                <option data-kid=\"99\">Yoon Suk-yeol</option>\n                                <option selected data-kid=\"100\">Unspecified Subject</option>\n                            </select>\n                        </div>\n                        <button class=\"bg-[#0F172A] text-[#FFFFFF] px-12 py-4 font-black uppercase tracking-widest hover:bg-[#2563EB] shadow-[4px_4px_0px_0px_#0F172A] hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px] transition-all\" onclick=\"startAnalysis()\" data-kid=\"101\">\n                            Execute_Process\n                        </button>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"analysis-stepper\" class=\"hidden p-12 lg:p-24 border-b border-[#0F172A] bg-[#F8FAFC]\" data-kid=\"102\">\n        <div class=\"max-w-4xl mx-auto\" data-kid=\"103\">\n            <div class=\"border border-[#0F172A] bg-white sharp-shadow overflow-hidden relative\" data-kid=\"104\">\n                \n                <div class=\"absolute top-2 right-12 font-mono text-[8px] text-[#64748B] opacity-20 select-none\" data-kid=\"105\">SEQ_01 // INTEL_UNIT_A</div>\n                \n                <div class=\"bg-[#0F172A] text-white p-4 flex justify-between items-center\" data-kid=\"106\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"107\">\n                        <i class=\"ti ti-terminal text-xl\" data-kid=\"108\"></i>\n                        <span class=\"font-mono text-sm tracking-widest uppercase\" data-kid=\"109\">System_Analyzer_Core</span>\n                    </div>\n                    <div class=\"flex gap-2\" data-kid=\"110\">\n                        <div class=\"w-3 h-3 border border-white\" data-kid=\"111\"></div>\n                        <div class=\"w-3 h-3 bg-white\" data-kid=\"112\"></div>\n                    </div>\n                </div>\n                \n                <div id=\"terminal-content\" class=\"p-8 font-mono text-sm space-y-3 min-h-[300px]\" data-kid=\"113\">\n                    \n                </div>\n\n                <div class=\"p-8 border-t border-[#0F172A] bg-[#F8FAFC]\" data-kid=\"114\">\n                    <div class=\"flex justify-between items-end mb-4\" data-kid=\"115\">\n                        <div data-kid=\"116\">\n                            <p class=\"font-bold text-[#0F172A] uppercase tracking-widest\" data-kid=\"117\">Active Pipeline</p>\n                            <p class=\"text-xs text-[#64748B] font-mono mt-1\" data-kid=\"118\">AXIS_01_CONSISTENCY // AXIS_02_FACTUALITY</p>\n                        </div>\n                        <div class=\"text-right\" data-kid=\"119\">\n                            <p class=\"font-mono text-xl font-bold text-[#0F172A]\" data-kid=\"120\"><span id=\"progress-val\" data-kid=\"121\">0</span>%</p>\n                        </div>\n                    </div>\n                    <div class=\"h-10 w-full border border-[#0F172A] flex p-1 gap-1 bg-white\" data-kid=\"122\">\n                        <div id=\"progress-bar-container\" class=\"flex gap-1 w-full h-full\" data-kid=\"123\">\n                            \n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"result-dashboard\" class=\"hidden p-12 lg:p-24 border-b border-navy bg-white\" data-kid=\"124\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"125\">\n            <div class=\"flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-8\" data-kid=\"126\">\n                <div data-kid=\"127\">\n                    <div class=\"inline-block bg-navy text-white px-3 py-1 font-mono text-[10px] uppercase mb-4\" data-kid=\"128\">Report_Generated: 2024-07-08</div>\n                    <h2 class=\"text-5xl font-black uppercase tracking-tighter\" data-kid=\"129\">Analytical Dashboard</h2>\n                    <p class=\"font-mono text-xs text-gray mt-2\" data-kid=\"130\">VERDICT_SUMMARY // CONFIDENCE_INTERVAL_95%</p>\n                </div>\n                <div class=\"flex gap-4\" data-kid=\"131\">\n                    <button class=\"btn-secondary py-2 px-6 text-xs\" data-kid=\"132\"><i class=\"ti ti-download mr-2\" data-kid=\"133\"></i>Export JSON</button>\n                    <button class=\"btn-secondary py-2 px-6 text-xs\" data-kid=\"134\"><i class=\"ti ti-printer mr-2\" data-kid=\"135\"></i>PDF Report</button>\n                </div>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 mb-20\" data-kid=\"136\">\n                \n                <div class=\"border border-navy p-8 bg-white sharp-shadow-sm flex flex-col justify-between\" data-kid=\"137\">\n                    <div data-kid=\"138\">\n                        <div class=\"flex justify-between items-start mb-6\" data-kid=\"139\">\n                            <h3 class=\"font-bold uppercase tracking-widest text-blue text-sm\" data-kid=\"140\">Consistency Score</h3>\n                            <span class=\"font-mono text-4xl font-black text-navy\" data-kid=\"141\">72%</span>\n                        </div>\n                        <div class=\"flex gap-1 h-8 segment-bar mb-6\" data-kid=\"142\">\n                            <div class=\"bg-blue\" data-kid=\"143\"></div><div class=\"bg-blue\" data-kid=\"144\"></div><div class=\"bg-blue\" data-kid=\"145\"></div><div class=\"bg-blue\" data-kid=\"146\"></div><div class=\"bg-blue\" data-kid=\"147\"></div><div class=\"bg-blue\" data-kid=\"148\"></div><div class=\"bg-blue\" data-kid=\"149\"></div>\n                            <div class=\"bg-slate\" data-kid=\"150\"></div><div class=\"bg-slate\" data-kid=\"151\"></div><div class=\"bg-slate\" data-kid=\"152\"></div>\n                        </div>\n                    </div>\n                    <p class=\"text-[10px] font-mono text-gray uppercase leading-relaxed\" data-kid=\"153\">Percentage of statements that do not contradict historical database records (N=452).</p>\n                </div>\n\n                \n                <div class=\"border border-navy p-8 bg-white sharp-shadow-sm flex flex-col justify-between\" data-kid=\"154\">\n                    <div data-kid=\"155\">\n                        <div class=\"flex justify-between items-start mb-6\" data-kid=\"156\">\n                            <h3 class=\"font-bold uppercase tracking-widest text-green text-sm\" data-kid=\"157\">Factuality Score</h3>\n                            <span class=\"font-mono text-4xl font-black text-navy\" data-kid=\"158\">64%</span>\n                        </div>\n                        <div class=\"flex gap-1 h-8 segment-bar mb-6\" data-kid=\"159\">\n                            <div class=\"bg-green\" data-kid=\"160\"></div><div class=\"bg-green\" data-kid=\"161\"></div><div class=\"bg-green\" data-kid=\"162\"></div><div class=\"bg-green\" data-kid=\"163\"></div><div class=\"bg-green\" data-kid=\"164\"></div><div class=\"bg-green\" data-kid=\"165\"></div>\n                            <div class=\"bg-slate\" data-kid=\"166\"></div><div class=\"bg-slate\" data-kid=\"167\"></div><div class=\"bg-slate\" data-kid=\"168\"></div><div class=\"bg-slate\" data-kid=\"169\"></div>\n                        </div>\n                    </div>\n                    <p class=\"text-[10px] font-mono text-gray uppercase leading-relaxed\" data-kid=\"170\">Percentage of factual claims verified as TRUE against official statistical repositories.</p>\n                </div>\n\n                \n                <div class=\"border border-navy p-8 bg-white sharp-shadow-sm\" data-kid=\"171\">\n                    <h3 class=\"font-bold uppercase tracking-widest text-navy text-sm mb-8\" data-kid=\"172\">Statement Breakdown</h3>\n                    <div class=\"space-y-4\" data-kid=\"173\">\n                        <div class=\"flex justify-between font-mono text-xs border-b border-navy/10 pb-2\" data-kid=\"174\">\n                            <span class=\"text-gray uppercase\" data-kid=\"175\">Total Extracted</span>\n                            <span class=\"font-bold\" data-kid=\"176\">18</span>\n                        </div>\n                        <div class=\"flex justify-between font-mono text-xs border-b border-navy/10 pb-2\" data-kid=\"177\">\n                            <span class=\"text-red uppercase font-bold\" data-kid=\"178\">Contradictions</span>\n                            <span class=\"font-bold\" data-kid=\"179\">05</span>\n                        </div>\n                        <div class=\"flex justify-between font-mono text-xs border-b border-navy/10 pb-2\" data-kid=\"180\">\n                            <span class=\"text-red uppercase font-bold\" data-kid=\"181\">False Claims</span>\n                            <span class=\"font-bold\" data-kid=\"182\">03</span>\n                        </div>\n                        <div class=\"flex justify-between font-mono text-xs border-b border-navy/10 pb-2\" data-kid=\"183\">\n                            <span class=\"text-orange uppercase font-bold\" data-kid=\"184\">Unverifiable</span>\n                            <span class=\"font-bold\" data-kid=\"185\">04</span>\n                        </div>\n                        <div class=\"flex justify-between font-mono text-xs pb-2\" data-kid=\"186\">\n                            <span class=\"text-green uppercase font-bold\" data-kid=\"187\">Verified Correct</span>\n                            <span class=\"font-bold\" data-kid=\"188\">06</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"space-y-8\" data-kid=\"189\">\n                <div class=\"flex items-center gap-4 mb-8\" data-kid=\"190\">\n                    <div class=\"h-[1px] flex-grow bg-navy/10\" data-kid=\"191\"></div>\n                    <span class=\"font-mono text-xs text-gray uppercase tracking-widest\" data-kid=\"192\">End_of_Summary // Beginning_of_Claim_Ledger</span>\n                    <div class=\"h-[1px] flex-grow bg-navy/10\" data-kid=\"193\"></div>\n                </div>\n\n                \n                <div class=\"statement-card border border-[#0F172A] bg-white overflow-hidden transition-colors duration-300\" data-kid=\"194\">\n                    <div class=\"flex\" data-kid=\"195\">\n                        <div class=\"w-3 bg-[#DC2626]\" data-kid=\"196\"></div>\n                        <div class=\"flex-grow p-8\" data-kid=\"197\">\n                            <div class=\"flex flex-wrap justify-between items-center gap-4 mb-6\" data-kid=\"198\">\n                                <div class=\"flex gap-4\" data-kid=\"199\">\n                                    <span class=\"font-mono text-xs bg-[#0F172A] text-white px-3 py-1 uppercase\" data-kid=\"200\">00:01:24</span>\n                                    <span class=\"font-mono text-xs border border-[#0F172A] px-3 py-1 uppercase\" data-kid=\"201\">CLAIM_ID: 03</span>\n                                </div>\n                                <div class=\"flex gap-2\" data-kid=\"202\">\n                                    <div class=\"bg-[#DC2626] text-white text-[10px] font-bold px-3 py-1 uppercase tracking-widest border border-[#0F172A]\" data-kid=\"203\">CONTRADICTION</div>\n                                    <div class=\"bg-[#DC2626] text-white text-[10px] font-bold px-3 py-1 uppercase tracking-widest border border-[#0F172A]\" data-kid=\"204\">FALSE</div>\n                                    <div class=\"bg-white text-[#0F172A] text-[10px] font-bold px-3 py-1 uppercase tracking-widest border border-[#0F172A]\" data-kid=\"205\">CONFIDENCE: 0.82</div>\n                                </div>\n                            </div>\n                            <h4 class=\"text-2xl font-black text-[#0F172A] mb-6 leading-tight max-w-4xl\" data-kid=\"206\">\n                                \"The youth unemployment rate has decreased by more than double compared to the previous administration.\"\n                            </h4>\n                            <div class=\"flex items-center justify-between\" data-kid=\"207\">\n                                <div class=\"flex items-center gap-8\" data-kid=\"208\">\n                                    <div class=\"flex items-center gap-2 text-xs font-mono text-[#64748B]\" data-kid=\"209\">\n                                        <i class=\"ti ti-link text-[#2563EB]\" data-kid=\"210\"></i>\n                                        <span data-kid=\"211\">[2_SOURCES]</span>\n                                    </div>\n                                    <div class=\"flex items-center gap-2 text-xs font-mono text-[#64748B]\" data-kid=\"212\">\n                                        <i class=\"ti ti-history text-[#2563EB]\" data-kid=\"213\"></i>\n                                        <span data-kid=\"214\">[1_PAST_STATEMENT]</span>\n                                    </div>\n                                </div>\n                                <button onclick=\"toggleEvidence('ev-1')\" class=\"font-bold text-xs uppercase tracking-widest flex items-center gap-2 hover:text-[#2563EB] transition-colors cursor-pointer\" data-kid=\"215\">\n                                    <span data-kid=\"216\">Expand_Technical_Evidence</span>\n                                    <i id=\"icon-ev-1\" class=\"ti ti-chevron-down text-lg\" data-kid=\"217\"></i>\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                    \n                    <div id=\"ev-1\" class=\"hidden border-t border-[#0F172A] bg-[#F8FAFC] p-12\" data-kid=\"218\">\n                        <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-16\" data-kid=\"219\">\n                            <div data-kid=\"220\">\n                                <h5 class=\"font-bold uppercase tracking-widest text-xs mb-6 flex items-center gap-2 text-blue\" data-kid=\"221\">\n                                    <i class=\"ti ti-git-branch\" data-kid=\"222\"></i>\n                                    Axis 01: Consistency Analysis\n                                </h5>\n                                <div class=\"space-y-6\" data-kid=\"223\">\n                                    <div data-kid=\"224\">\n                                        <p class=\"text-[10px] font-mono text-gray uppercase mb-3\" data-kid=\"225\">Detected_Conflicting_Statement:</p>\n                                        <div class=\"border border-navy bg-white p-6 text-sm italic relative\" data-kid=\"226\">\n                                            <i class=\"ti ti-quote text-navy/10 text-4xl absolute top-2 left-2\" data-kid=\"227\"></i>\n                                            \"The current economic indicators for young adults are the worst since the 1997 IMF crisis. We need a complete overhaul.\"\n                                        </div>\n                                    </div>\n                                    <div class=\"flex justify-between font-mono text-[10px] border-b border-navy/10 pb-2\" data-kid=\"228\">\n                                        <span data-kid=\"229\">RECORDED_DATE: 2024-03-12</span>\n                                        <span class=\"text-blue underline cursor-pointer\" data-kid=\"230\">[ARCHIVE_ID: KB-4012]</span>\n                                    </div>\n                                    <div class=\"p-4 bg-red/5 border-l-4 border-red\" data-kid=\"231\">\n                                        <p class=\"text-xs leading-relaxed\" data-kid=\"232\">\n                                            <span class=\"font-bold text-red uppercase mr-2\" data-kid=\"233\">Logic Verdict:</span> \n                                            System detected a direct logical contradiction. Current claim asserts \"record lows\" while the recorded statement from 4 months ago defines the same period as \"the worst crisis since 1997.\"\n                                        </p>\n                                    </div>\n                                </div>\n                            </div>\n                            <div data-kid=\"234\">\n                                <h5 class=\"font-bold uppercase tracking-widest text-xs mb-6 flex items-center gap-2 text-green\" data-kid=\"235\">\n                                    <i class=\"ti ti-database-check\" data-kid=\"236\"></i>\n                                    Axis 02: Factuality Analysis\n                                </h5>\n                                <div class=\"space-y-6\" data-kid=\"237\">\n                                    <div data-kid=\"238\">\n                                        <p class=\"text-[10px] font-mono text-gray uppercase mb-3\" data-kid=\"239\">Statistical_Validation_Model:</p>\n                                        <div class=\"border border-navy bg-white p-6\" data-kid=\"240\">\n                                            <div class=\"flex justify-between items-center mb-4\" data-kid=\"241\">\n                                                <span class=\"text-xs font-bold uppercase tracking-tighter\" data-kid=\"242\">KOSIS Q4 DATASET</span>\n                                                <span class=\"text-[10px] font-mono text-red\" data-kid=\"243\">DELTA_ERROR: -98.2%</span>\n                                            </div>\n                                            <div class=\"h-3 w-full bg-slate flex border border-navy/20 p-[2px]\" data-kid=\"244\">\n                                                <div class=\"w-[2%] bg-red\" data-kid=\"245\"></div>\n                                                <div class=\"flex-grow bg-slate\" data-kid=\"246\"></div>\n                                            </div>\n                                            <div class=\"mt-4 flex justify-between font-mono text-[9px] text-gray\" data-kid=\"247\">\n                                                <span data-kid=\"248\">REF: PREV_ADMIN (7.8%)</span>\n                                                <span data-kid=\"249\">REF: CUR_ADMIN (7.6%)</span>\n                                            </div>\n                                        </div>\n                                    </div>\n                                    <div class=\"space-y-2\" data-kid=\"250\">\n                                        <div class=\"font-mono text-[10px] flex items-center gap-3 group\" data-kid=\"251\">\n                                            <span class=\"bg-navy text-white px-2 py-[2px]\" data-kid=\"252\">REF_01</span>\n                                            <span class=\"text-gray truncate underline group-hover:text-green cursor-pointer\" data-kid=\"253\">kosis.kr/statHtml/employment_report_2024_Q2</span>\n                                        </div>\n                                        <div class=\"font-mono text-[10px] flex items-center gap-3 group\" data-kid=\"254\">\n                                            <span class=\"bg-navy text-white px-2 py-[2px]\" data-kid=\"255\">REF_02</span>\n                                            <span class=\"text-gray truncate underline group-hover:text-green cursor-pointer\" data-kid=\"256\">oecd-ilibrary.org/employment/youth-rates-korea</span>\n                                        </div>\n                                    </div>\n                                    <div class=\"p-4 bg-green/5 border-l-4 border-green\" data-kid=\"257\">\n                                        <p class=\"text-xs leading-relaxed\" data-kid=\"258\">\n                                            <span class=\"font-bold text-green uppercase mr-2\" data-kid=\"259\">Data Verdict:</span> \n                                            Statistical cross-referencing with KOSIS and OECD indicates a marginal 0.2 percentage point decrease. The claim \"decreased by more than double\" is mathematically impossible.\n                                        </p>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"statement-card border border-navy bg-white overflow-hidden transition-all duration-300\" data-kid=\"260\">\n                    <div class=\"flex\" data-kid=\"261\">\n                        <div class=\"w-3 bg-blue\" data-kid=\"262\"></div>\n                        <div class=\"flex-grow p-8\" data-kid=\"263\">\n                            <div class=\"flex flex-wrap justify-between items-center gap-4 mb-6\" data-kid=\"264\">\n                                <div class=\"flex gap-4\" data-kid=\"265\">\n                                    <span class=\"font-mono text-xs bg-navy text-white px-3 py-1 uppercase\" data-kid=\"266\">00:04:15</span>\n                                    <span class=\"font-mono text-xs border border-navy px-3 py-1 uppercase\" data-kid=\"267\">CLAIM_ID: 07</span>\n                                </div>\n                                <div class=\"flex gap-2\" data-kid=\"268\">\n                                    <div class=\"bg-blue text-white text-[10px] font-bold px-3 py-1 uppercase tracking-widest border border-navy\" data-kid=\"269\">CONSISTENT</div>\n                                    <div class=\"bg-green text-white text-[10px] font-bold px-3 py-1 uppercase tracking-widest border border-navy\" data-kid=\"270\">TRUE</div>\n                                    <div class=\"bg-white text-navy text-[10px] font-bold px-3 py-1 uppercase tracking-widest border border-navy\" data-kid=\"271\">CONFIDENCE: 0.95</div>\n                                </div>\n                            </div>\n                            <h4 class=\"text-2xl font-black text-navy mb-6 leading-tight max-w-4xl\" data-kid=\"272\">\n                                \"Our semiconductor exports to Southeast Asia have grown by 14% year-on-year.\"\n                            </h4>\n                            <div class=\"flex items-center justify-between\" data-kid=\"273\">\n                                <div class=\"flex items-center gap-8\" data-kid=\"274\">\n                                    <div class=\"flex items-center gap-2 text-xs font-mono text-gray\" data-kid=\"275\">\n                                        <i class=\"ti ti-link text-green\" data-kid=\"276\"></i>\n                                        <span data-kid=\"277\">[4_SOURCES]</span>\n                                    </div>\n                                    <div class=\"flex items-center gap-2 text-xs font-mono text-gray\" data-kid=\"278\">\n                                        <i class=\"ti ti-history text-blue\" data-kid=\"279\"></i>\n                                        <span data-kid=\"280\">[MATCH_FOUND]</span>\n                                    </div>\n                                </div>\n                                <button onclick=\"toggleEvidence('ev-2')\" class=\"font-bold text-xs uppercase tracking-widest flex items-center gap-2 hover:text-blue transition-colors\" data-kid=\"281\">\n                                    <span data-kid=\"282\">Expand_Technical_Evidence</span>\n                                    <i id=\"icon-ev-2\" class=\"ti ti-chevron-down text-lg\" data-kid=\"283\"></i>\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                    <div id=\"ev-2\" class=\"hidden border-t border-navy bg-slate p-12\" data-kid=\"284\">\n                         <p class=\"font-mono text-xs text-gray uppercase text-center italic\" data-kid=\"285\">Technical report for Claim_07 is consistent with official Ministry of Trade records. No anomalies detected.</p>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"mt-20 p-12 bg-navy text-white flex flex-col md:flex-row items-center justify-between gap-8\" data-kid=\"286\">\n                <div data-kid=\"287\">\n                    <h3 class=\"text-2xl font-bold uppercase tracking-widest mb-2\" data-kid=\"288\">Final Methodology Disclaimer</h3>\n                    <p class=\"text-xs text-white/60 font-mono leading-relaxed max-w-2xl\" data-kid=\"289\">\n                        AI-based analytical models provide initial verification. Human verification by certified journalists is required for legal or editorial publication. All sources are publicly available through the 'Data Sources' portal.\n                    </p>\n                </div>\n                <button class=\"bg-white text-navy px-8 py-4 font-bold uppercase tracking-widest hover:bg-blue hover:text-white transition-all\" data-kid=\"290\">Submit for Human Review</button>\n            </div>\n        </div>\n    </section>\n  </main>\n\n  <footer class=\"border-t border-navy bg-white py-12 px-8\" data-kid=\"291\">\n    <div class=\"max-w-[1440px] mx-auto flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"292\">\n        <div class=\"flex items-center gap-4\" data-kid=\"293\">\n            <div class=\"w-8 h-8 bg-navy flex items-center justify-center\" data-kid=\"294\">\n                <i class=\"ti ti-git-fork text-white text-lg\" data-kid=\"295\"></i>\n            </div>\n            <span class=\"font-bold text-sm uppercase tracking-tighter\" data-kid=\"296\">Research Anthropologist Desk // Ver_1.0.4</span>\n        </div>\n        <div class=\"font-mono text-[10px] text-gray uppercase flex gap-8\" data-kid=\"297\">\n            <span data-kid=\"298\">&copy; 2024 Evidence Desk Intelligence</span>\n            <a href=\"#\" class=\"hover:text-navy\" data-kid=\"299\">Privacy Protocol</a>\n            <a href=\"#\" class=\"hover:text-navy\" data-kid=\"300\">Terminal Access</a>\n        </div>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"301\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"302\"></script>\n<script data-kid=\"303\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  function scrollToAnalysis() {\n    const el = document.getElementById('analysis-panel');\n    el.scrollIntoView({ behavior: 'smooth' });\n  }\n\n  function startAnalysis() {\n    const stepper = document.getElementById('analysis-stepper');\n    stepper.classList.remove('hidden');\n    stepper.scrollIntoView({ behavior: 'smooth' });\n    \n    runTerminalSimulation();\n  }\n\n  function runTerminalSimulation() {\n    const terminal = document.getElementById('terminal-content');\n    const progressBarContainer = document.getElementById('progress-bar-container');\n    const progressVal = document.getElementById('progress-val');\n    \n    terminal.innerHTML = '';\n    progressBarContainer.innerHTML = '';\n    \n    const logs = [\n        { time: '12:04:01', msg: 'Initializing Speech-to-Text conversion engine...', status: 'DONE' },\n        { time: '12:04:05', msg: 'Extracting claim segments from transcript... (18 segments found)', status: 'DONE' },\n        { time: '12:04:12', msg: 'Cross-referencing historical statement database...', status: 'PROCESSING', active: true },\n        { time: '12:04:45', msg: 'Verifying statistical claims against official KOSIS / WEB repositories...', status: 'WAITING' },\n        { time: '12:05:12', msg: 'Synthesizing final analytical report...', status: 'WAITING' }\n    ];\n\n    logs.forEach((log, index) => {\n        setTimeout(() => {\n            const row = document.createElement('div');\n            row.className = `flex items-start gap-4 text-gray ${log.active ? 'border-l-4 border-orange pl-4 py-1 bg-orange/5' : ''}`;\n            row.innerHTML = `\n                <span>[${log.time}]</span>\n                <span class=\"text-navy ${log.active ? 'font-bold' : ''}\">${log.msg}</span>\n                <span class=\"ml-auto ${log.status === 'DONE' ? 'text-green' : (log.status === 'PROCESSING' ? 'text-orange animate-pulse' : 'text-gray/40')}\">${log.status}</span>\n            `;\n            terminal.appendChild(row);\n            \n            // Update Progress Bar\n            updateProgressBar(index + 1, logs.length);\n        }, index * 1000);\n    });\n\n    // Final show dashboard after some time\n    setTimeout(() => {\n        const dashboard = document.getElementById('result-dashboard');\n        dashboard.classList.remove('hidden');\n        gsap.from(dashboard, { opacity: 0, y: 50, duration: 1, ease: 'power4.out' });\n        dashboard.scrollIntoView({ behavior: 'smooth' });\n    }, logs.length * 1000 + 1000);\n  }\n\n  function updateProgressBar(current, total) {\n    const progressBarContainer = document.getElementById('progress-bar-container');\n    const progressVal = document.getElementById('progress-val');\n    const percentage = Math.round((current / total) * 100);\n    \n    progressVal.innerText = percentage;\n    \n    progressBarContainer.innerHTML = '';\n    const segmentCount = 20;\n    const filledSegments = Math.round((percentage / 100) * segmentCount);\n    \n    for(let i=0; i<segmentCount; i++) {\n        const seg = document.createElement('div');\n        seg.className = `h-full flex-grow ${i < filledSegments ? 'bg-navy' : 'bg-navy/10'}`;\n        progressBarContainer.appendChild(seg);\n    }\n  }\n\n  function toggleEvidence(id) {\n    const el = document.getElementById(id);\n    const icon = document.getElementById('icon-' + id);\n    if (el.classList.contains('hidden')) {\n        el.classList.remove('hidden');\n        icon.classList.replace('ti-chevron-down', 'ti-chevron-up');\n        gsap.from(el, { height: 0, opacity: 0, duration: 0.5, ease: 'power2.out' });\n    } else {\n        gsap.to(el, { height: 0, opacity: 0, duration: 0.3, ease: 'power2.in', onComplete: () => {\n            el.classList.add('hidden');\n            el.style.height = 'auto';\n            el.style.opacity = '1';\n        }});\n        icon.classList.replace('ti-chevron-up', 'ti-chevron-down');\n    }\n  }\n\n  // Entrance Animations\n  window.addEventListener('load', () => {\n    gsap.from(\"header\", { y: -100, opacity: 0, duration: 1, ease: \"power4.out\" });\n    gsap.from(\"h1\", { x: -100, opacity: 0, duration: 1, delay: 0.5, ease: \"power4.out\" });\n    gsap.from(\".sharp-shadow\", { scale: 0.9, opacity: 0, duration: 1, delay: 0.8, ease: \"back.out(1.7)\" });\n  });\n</script>\n",
