# Copy to .env.local and fill in.

# LLM backend. Leave unset (or anything but "local") to use the Anthropic cloud API.
# Set to "local" to run all reasoning on a local Ollama model — no API credits, and
# Axis 2 then searches the web in code (DuckDuckGo) instead of a provider tool.
#   brew install ollama && ollama serve && ollama pull qwen2.5:14b
# LLM_BACKEND=local
# OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_URL=http://127.0.0.1:11434

# Anthropic (Claude) — REQUIRED unless LLM_BACKEND=local.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — grounds Korean statistical claims in official KOSIS data.
# Get a key at https://kosis.kr/openapi/ (활용신청 → 인증키). Fact-check still
# works without it (falls back to web search).
KOSIS_KEY=

# French statistics (INSEE BDM "Séries chronologiques") — KEYLESS / open access.
# No key needed; the client calls it directly. Optional overrides only.
# INSEE_BASE=https://api.insee.fr/series/BDM/V1

# Optional — MongoDB cache (fact-check verdicts + official figures). Works without it.
# MONGODB_URI=mongodb://user:pass@host:27017/?authSource=admin
# MONGODB_DB=media_hackaton
