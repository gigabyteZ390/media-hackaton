[
  { "id": "lee-econ-01", "politician": "이재명", "text": "내년부터 연간 25만원의 기본소득을 모든 국민들에게 지급하는 것부터 시작하려고 한다. 부분적 기본소득은 증세 없이 현재 세원제도를 갖고 감당 가능하다.", "date": "2022-01-06", "sourceUrl": "https://www.khan.co.kr/article/202201062214001", "topic": "기본소득", "confidence": "high" },
  { "id": "lee-econ-02", "politician": "이재명", "text": "연간 25만원, 1회 지급은 총 13조원 정도에 불과하다. 합쳐서 20조원이 되는 건데 (한 해 예산인) 600조원의 3%에 불과해 얼마든지 할 수 있다.", "date": "2022-01-06", "sourceUrl": "https://www.khan.co.kr/article/202201062214001", "topic": "기본소득", "confidence": "high" },
  { "id": "lee-econ-03", "politician": "이재명", "text": "기본소득은 (단순 복지가 아니라) 복지적 형태를 가진 경제정책이다. 욕심내지 말고 1년에 1~4번씩 늘려 가면 충분히 가능하다.", "date": "2020", "sourceUrl": "https://gnews.gg.go.kr/briefing/brief_gongbo_view.do?BS_CODE=s017&number=45206&subject_Code=BO01", "topic": "기본소득", "confidence": "medium" },
  { "id": "lee-econ-04", "politician": "이재명", "text": "망국적인 부동산투기를 막으려면 토지거래세를 줄이고, 0.17%에 불과한 실효보유세를 1% 선까지 점차 늘려가야 한다. 이를 전액 국민에게 기본소득으로 지급해 조세저항을 줄여야 한다.", "date": "2021-08-03", "sourceUrl": "https://www.fnnews.com/news/202108031357360360", "topic": "조세", "confidence": "high" },
  { "id": "lee-econ-05", "politician": "이재명", "text": "국토보유세를 걷어 전액 국민에게 기본소득으로 배분하겠다. 전국민 90%가 수혜를 보는 기본소득 토지세다.", "date": "2021-11", "sourceUrl": "https://www.hankyung.com/politics/article/202111159126Y", "topic": "조세", "confidence": "medium" },
  { "id": "lee-econ-06", "politician": "이재명", "text": "실거주자 외엔 부동산으로 생기는 불로소득을 100% 환수하면 된다. 불로소득을 적절하게 환수해 투기적 이익이 생기지 않게 만들면 된다.", "date": "2020-07-29", "sourceUrl": "https://www.hankookilbo.com/News/Read/A2020073006130002655", "topic": "부동산", "confidence": "high" },
  { "id": "lee-econ-07", "politician": "이재명", "text": "부동산을 투기나 투자로 보유하는 것은 하나 마나다, 이런 생각이 들게 만들어야 한다. 세제·규제·금융 등의 방법으로 부동산이 돈 되지 않는 나라를 만들어야 한다.", "date": "2026-02-24", "sourceUrl": "https://namu.wiki/w/이재명 정부/평가/경제/부동산 정책", "topic": "부동산", "confidence": "medium" },
  { "id": "lee-econ-08", "politician": "이재명", "text": "세금은 전쟁으로 치면 핵폭탄과 같은 것이라 함부로 사용해서는 안 되는 최후의 수단이다. 그럼에도 불구하고 반드시 필요한 상황이 오면 사용할 수밖에 없다.", "date": "2026-03-17", "sourceUrl": "https://www.intn.co.kr/news/articleView.html?idxno=2049610", "topic": "부동산", "confidence": "high" },
  { "id": "lee-econ-09", "politician": "이재명", "text": "세금으로 부동산시장 안정화를 하지 않겠다. 세금은 다른 제재 수단으로 사용되면 정당성을 얻기 어려우며, 공급을 늘려 적정한 가격을 유지하도록 하겠다.", "date": "2025", "sourceUrl": "https://namu.wiki/w/이재명 정부/평가/경제/부동산 정책", "topic": "부동산", "confidence": "medium" },
  { "id": "lee-econ-10", "politician": "이재명", "text": "현금으로 주는 것보다는 지역화폐 형태로 지급해야 골목상권에 돈이 빨리 돌고 경기 순환에 도움이 된다. 가난한 사람들에게 돈을 주면 많이 쓰지만 부자들한테는 100만 원을 줘 봐야 안 쓴다.", "date": "2026-03-24", "sourceUrl": "https://imnews.imbc.com/news/2026/politics/article/6809888_36911.html", "topic": "지역화폐", "confidence": "high" },
  { "id": "lee-econ-11", "politician": "이재명", "text": "지역화폐는 매출 자체를 올리는 게 아니라 (해당 지역 상권으로) 매출을 이동하는 것이다.", "date": "2025-12-17", "sourceUrl": "https://v.daum.net/v/20251217150500650", "topic": "지역화폐", "confidence": "medium" },
  { "id": "lee-econ-12", "politician": "이재명", "text": "(전국민 민생회복지원금은) 퍼주기가 아니라 국민의 세금을 국민에게 돌려드리는 것이다. 지금은 민간이 과도하게 침체된 상황으로 정부가 적극 개입해야 한다.", "date": "2026-03-24", "sourceUrl": "https://imnews.imbc.com/news/2026/politics/article/6809888_36911.html", "topic": "재난지원금", "confidence": "high" },
  { "id": "lee-econ-13", "politician": "이재명", "text": "전국민 재난지원금 지급의 대상과 방식을 고집하지 않겠다. 지급 논의는 추후에 검토해도 된다. 합의 가능한 것부터 시행하겠다.", "date": "2021-11-18", "sourceUrl": "https://www.nocutnews.co.kr/news/5659532", "topic": "재난지원금", "confidence": "high" },
  { "id": "lee-econ-14", "politician": "이재명", "text": "민생회복과 경제 살리기부터 시작하겠다. 벼랑 끝에 몰린 민생을 되살리고, 성장을 회복해 모두가 행복한 내일을 만들어갈 시간이다.", "date": "2025-06-04", "sourceUrl": "https://www.mofa.go.kr/us-ko/brd/m_4487/view.do?seq=1347789", "topic": "경제", "confidence": "high" },
  { "id": "lee-econ-15", "politician": "이재명", "text": "경제 회복을 해야 하는 시점이고 성장이 우선이다. 기업이 앞장서고 국가가 뒷받침해 다시 성장의 길을 열어야 한다. 민간 주도 정부 지원의 시대로 전환해야 한다.", "date": "2025-04-14", "sourceUrl": "https://www.asiae.co.kr/article/2025041419045274458", "topic": "경제", "confidence": "high" },
  { "id": "lee-econ-16", "politician": "이재명", "text": "지금은 나누어 분배하는 문제보다 만들고 성장하는 일이 더 시급하다. (자신의 대표 공약인 기본소득·기본사회 재검토를) 심각하게 고민 중이다.", "date": "2025-01", "sourceUrl": "https://www.asiae.co.kr/article/2025041419045274458", "topic": "기본소득", "confidence": "medium" },
  { "id": "lee-econ-17", "politician": "이재명", "text": "소득·주거·돌봄·교육 등 모든 영역에 사회안전망을 갖추고 국민의 '기본'을 보장하는 기본사회를 실현하겠다. 주거·의료·돌봄·교육·교통까지 삶 전반을 국가가 보장하겠다.", "date": "2025-05-22", "sourceUrl": "https://www.khan.co.kr/article/202505222106015", "topic": "복지", "confidence": "medium" },

  { "id": "lee-pol-01", "politician": "이재명", "text": "검찰이 기소하기 위해 목표를 정해놓고 수사를 하고 있다. 더 이상 기소하기 위해 수사할 수 없도록 수사권과 기소권을 동시에 갖고 있는 시스템을 끝내야 한다.", "date": "2025-04-25", "sourceUrl": "https://www.nocutnews.co.kr/news/6330822", "topic": "검찰개혁", "confidence": "high" },
  { "id": "lee-pol-02", "politician": "이재명", "text": "검찰개혁의 핵심은 수사와 기소를 분리해 검사의 수사권을 배제하는 것이다.", "date": "2026-03-16", "sourceUrl": "https://imnews.imbc.com/news/2026/politics/article/6807799_36911.html", "topic": "검찰개혁", "confidence": "high" },
  { "id": "lee-pol-03", "politician": "이재명", "text": "검찰개혁이 본질과 괴리된 과도한 선명성 경쟁이나 검찰개혁의 본질과 무관한 다른 목적에 의한 것이어서는 안 된다. 검찰청을 공소청으로 바꿨더니 이제 와서 검찰총장을 공소청장으로 바꿔야 한다는 것은 과유불급이다.", "date": "2026-03-16", "sourceUrl": "https://imnews.imbc.com/news/2026/politics/article/6807799_36911.html", "topic": "검찰개혁", "confidence": "high" },
  { "id": "lee-pol-04", "politician": "이재명", "text": "검찰의 수사권과 기소권을 분리하고, 공수처(고위공직자범죄수사처)는 규모와 권한을 확장해 대폭 강화해야 한다.", "date": "2025-04-15", "sourceUrl": "https://www.asiae.co.kr/article/2025041517470780075", "topic": "검찰개혁", "confidence": "medium" },
  { "id": "lee-pol-06", "politician": "이재명", "text": "대통령 4년 연임제 도입으로 정권에 대한 중간 평가가 가능해지면 그 책임성 또한 강화될 것이다.", "date": "2025-05-18", "sourceUrl": "https://www.khan.co.kr/article/202505181750001", "topic": "개헌", "confidence": "high" },
  { "id": "lee-pol-07", "politician": "이재명", "text": "대통령 결선투표제 도입으로 민주적 정당성을 확보해 불필요한 사회적 갈등을 최소화해야 한다.", "date": "2025-05-18", "sourceUrl": "https://www.khan.co.kr/article/202505181750001", "topic": "선거제도", "confidence": "high" },
  { "id": "lee-pol-08", "politician": "이재명", "text": "본인과 직계가족의 부정부패·범죄 관련 법안에 대해서는 대통령이 원천적으로 거부권을 행사할 수 없도록 해야 한다.", "date": "2025-05-18", "sourceUrl": "https://www.khan.co.kr/article/202505181750001", "topic": "개헌", "confidence": "high" },
  { "id": "lee-pol-09", "politician": "이재명", "text": "더 이상 감사원이 대통령을 지원하는 기관이라는 의혹과 우려를 낳아서는 안 된다. 감사원을 국회 소속으로 이관해야 한다.", "date": "2025-05-18", "sourceUrl": "https://www.khan.co.kr/article/202505181750001", "topic": "개헌", "confidence": "high" },
  { "id": "lee-pol-10", "politician": "이재명", "text": "국무총리 국회 추천제(책임총리제) 도입으로 대통령의 권한을 분산해야 한다.", "date": "2025-05-18", "sourceUrl": "https://www.newsis.com/view/NISX20250518_0003180083", "topic": "개헌", "confidence": "medium" },
  { "id": "lee-pol-11", "politician": "이재명", "text": "필요하다면 여야 간에 의견 일치가 된다면 선거관리위원회에 대한 원포인트 개헌이라도 해야 하지 않을까 생각한다. 필요하다면 대통령이 발의하는 한이 있더라도 (할 수 있다).", "date": "2026-06-19", "sourceUrl": "https://www.lawtimes.co.kr/news/articleView.html?idxno=222280", "topic": "개헌", "confidence": "high" },
  { "id": "lee-pol-12", "politician": "이재명", "text": "헌법이 선관위를 너무 명징하게 독립기관으로 해 놨기 때문에 감시·통제·견제의 법 제도를 만드는 게 위헌 결정을 받을 가능성이 크다.", "date": "2026-06-19", "sourceUrl": "https://www.lawtimes.co.kr/news/articleView.html?idxno=222280", "topic": "선거제도", "confidence": "high" },
  { "id": "lee-pol-13", "politician": "이재명", "text": "저에 대한 정치수사에 대해 불체포 권리를 포기하겠다. 구속영장을 청구하면 제 발로 출석해 영장실질심사를 받고 검찰의 무도함을 밝히겠다.", "date": "2023-06-19", "sourceUrl": "https://www.sedaily.com/NewsView/29QWZF1QKR", "topic": "정치개혁", "confidence": "high" },
  { "id": "lee-pol-14", "politician": "이재명", "text": "언론만 타깃으로 하지 말고, 누구든 악의를 가지고 가짜 정보를 만들면 배상 책임을 엄격하게 물어야 한다. 악의라는 조건은 엄격하게 하되 배상액은 아주 크게 하자.", "date": "2025-09-11", "sourceUrl": "https://www.hankookilbo.com/news/article/A2025091115440005273", "topic": "언론", "confidence": "high" },
  { "id": "lee-pol-16", "politician": "이재명", "text": "언론이 허위사실로 정책에 혼선을 주는 경우 처벌 방안을 검토하라.", "date": "2026-05-20", "sourceUrl": "https://www.mt.co.kr/politics/2026/05/20/2026052016202738002", "topic": "언론", "confidence": "medium" },

  { "id": "lee-etc-01", "politician": "이재명", "text": "미국과는 동맹으로서 특별한 관계가 있기 때문에 잘 활용해야 한다. 일방적으로 끌려다니는 것은 옳지 않다. 미리 저자세로 굴종할 필요 없이 협상해야 한다.", "date": "2025-02-24", "sourceUrl": "https://biz.heraldcorp.com/article/10427554", "topic": "외교", "confidence": "high" },
  { "id": "lee-etc-02", "politician": "이재명", "text": "국익 중심의 실용외교를 통해 글로벌 경제·안보 환경 대전환의 위기를 국익 극대화의 기회로 만들겠다. 굳건한 한미동맹을 토대로 한미일 협력을 다지겠다.", "date": "2025-06-04", "sourceUrl": "https://overseas.mofa.go.kr/us-ko/brd/m_4487/view.do?seq=1347789", "topic": "외교", "confidence": "high" },
  { "id": "lee-etc-03", "politician": "이재명", "text": "한미동맹은 외교의 근간이지만, 한미일 협력은 신중해야 한다.", "date": "2023-04-11", "sourceUrl": "https://www.rfa.org/korean/in_focus/nk_nuclear_talks/ljm-04112023082224.html", "topic": "외교", "confidence": "medium" },
  { "id": "lee-etc-05", "politician": "이재명", "text": "북한 체제를 존중하고 흡수통일을 추구하지 않으며 적대행위를 하지 않겠다. 미래의 통일보다 당면한 평화 정착을 중시한다(평화공존 3원칙).", "date": "2025", "sourceUrl": "https://www.korea.kr/news/policyNewsView.do?newsId=148959802", "topic": "대북", "confidence": "medium" },
  { "id": "lee-etc-07", "politician": "이재명", "text": "박근혜 정부의 위안부 합의와 윤석열 정부의 강제징용 제3자 변제 합의는 한국 국민으로서 받아들이기 힘든 전 정권의 합의지만, 국가 간 약속이므로 뒤집는 것은 바람직하지 않다.", "date": "2025-08-21", "sourceUrl": "https://www.hankyung.com/article/2025082142371", "topic": "한일관계", "confidence": "high" },
  { "id": "lee-etc-09", "politician": "이재명", "text": "한국과 일본은 서로에게 뗄 수 없는 관계라는 점이 분명하다. 서로 오해와 갈등을 최소화하며 미래지향적인 협력적 관계로 나아가야 한다.", "date": "2026", "sourceUrl": "https://imnews.imbc.com/news/2026/politics/article/6793017_36912.html", "topic": "한일관계", "confidence": "medium" },
  { "id": "lee-etc-10", "politician": "이재명", "text": "사드를 수도권에 배치한다고 하는데 사드가 수도권 방어에 도움이 되겠느냐. 안보 불안 심리를 자극하는 국익을 해치는 행위다.", "date": "2022-02-02", "sourceUrl": "https://www.newsis.com/view/NISX20220202_0001744402", "topic": "국방", "confidence": "high" },
  { "id": "lee-etc-11", "politician": "이재명", "text": "자주국방 의지가 있어야 친구도 우리를 존중하고 동맹도 더 굳건하게 유지될 수 있다. 한미 동맹의 건강한 발전을 견인할 전작권 환수를 차질없이 신속히 진행해달라.", "date": "2026-05-26", "sourceUrl": "https://www.sedaily.com/article/20048117", "topic": "국방", "confidence": "high" },
  { "id": "lee-etc-12", "politician": "이재명", "text": "주4.5일제를 도입하고 궁극적으로는 주4일제를 실현해 2030년까지 우리나라 평균 근로시간을 OECD 평균 이하로 단축하겠다.", "date": "2025-05", "sourceUrl": "https://www.worklaw.co.kr/main2022/view/view.asp?bi_pidx=37926", "topic": "노동", "confidence": "high" },
  { "id": "lee-etc-13", "politician": "이재명", "text": "(주4.5일제는) 시점을 특정하지는 못하지만 가능하면 빨리 하고 싶다. 노동 시간 단축을 반드시 해내야 하며, 사회적 합의를 통해 가능한 부분부터 점진적으로 해나가야 한다.", "date": "2025-07-03", "sourceUrl": "https://www.hankyung.com/article/2025070370351", "topic": "노동", "confidence": "high" },
  { "id": "lee-etc-14", "politician": "이재명", "text": "안정적인 일자리와 소득을 통해 자산을 형성할 기회 자체가 부족한 청년세대는 현실의 가장 큰 소외자다. '기회의 사다리' 확대를 추진하겠다.", "date": "2026-06", "sourceUrl": "https://www.ohmynews.com/NWS_Web/View/at_pg.aspx?CNTN_CD=A0003245565&PAGE_CD=N0002&CMPT_CD=M0112", "topic": "청년", "confidence": "high" },
  { "id": "lee-etc-15", "politician": "이재명", "text": "청년미래적금(가칭) 신설, 청년 맞춤형 공공 분양·임대 확대, 청년교통패스, 가상자산 제도화 등 청년 자산형성·주거·복지 공약을 추진하겠다.", "date": "2025-05-06", "sourceUrl": "https://news.nate.com/view/20250506n07791", "topic": "청년", "confidence": "high" },
  { "id": "lee-etc-16", "politician": "이재명", "text": "저출생의 핵심 원인은 미래에 대한 불안이며, 그 대책은 불안의 해소다. 국가 역량을 총동원해 결혼·출산·양육·교육·취업을 아우르는 포괄적 종합대책을 수립·추진해야 한다.", "date": "2024-04-29", "sourceUrl": "https://m.nocutnews.co.kr/news/amp/6137442", "topic": "저출생", "confidence": "high" },
  { "id": "lee-etc-17", "politician": "이재명", "text": "지금 당장 엄청난 전력이 필요한데, 가장 신속하게 공급할 수 있는 에너지 시스템은 태양광·풍력 같은 재생에너지다. 관련 인프라·전력망을 깔아 재생에너지 산업을 대대적으로 키우겠다.", "date": "2025-09-11", "sourceUrl": "https://www.khan.co.kr/article/202509111628001", "topic": "에너지", "confidence": "high" },
  { "id": "lee-etc-18", "politician": "이재명", "text": "원자력발전소를 짓는 데에만 15년 걸린다. 다만 원전도 있는 것은 쓰고 가동 기간이 지난 것도 안전성이 담보되면 연장해 쓰며, 원자력과 재생에너지를 합리적으로 섞는 에너지 믹스 정책은 변한 게 없다.", "date": "2025-09-11", "sourceUrl": "https://www.khan.co.kr/article/202509111628001", "topic": "에너지", "confidence": "high" }
]
